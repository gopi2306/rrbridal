<Window x:Class="RRBridal.StoreBilling.App.MainWindow"
        x:Name="ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:RRBridal.StoreBilling.App.ViewModels"
        xmlns:views="clr-namespace:RRBridal.StoreBilling.App.Views"
        xmlns:controls="clr-namespace:RRBridal.StoreBilling.App.Views.Controls"
        mc:Ignorable="d"
        Title="{Binding WindowTitleText}"
        Icon="pack://application:,,,/Resources/Assets/TruBill.ico"
        MinHeight="600"
        MinWidth="1024"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">
    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ShowHelpCommand}"/>
        <KeyBinding Key="F2" Command="{Binding ClearForNewBillCommand}"/>
        <KeyBinding Key="F4" Command="{Binding SaveCustomerRegistrationCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelCustomerRegistrationCommand}"/>
        <KeyBinding Key="F9" Command="{Binding PostBillCommand}"/>
        <KeyBinding Key="F10" Command="{Binding PrintStubCommand}"/>
        <KeyBinding Key="F8" Command="{Binding HoldBillCommand}"/>
        <KeyBinding Key="F11" Command="{Binding OpenDuplicateBillCommand}"/>
        <KeyBinding Key="F12" Command="{Binding CloseAppCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource BrushHeaderBar}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,0,1"
                Padding="12,8"
                Effect="{StaticResource CardShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="40" Height="40"
                                Style="{StaticResource GhostNavButton}"
                                Margin="0,0,8,0"
                                Command="{Binding ToggleNavDrawerCommand}"
                                ToolTip="Open navigation menu">
                            <Viewbox Width="20" Height="20" Stretch="Uniform">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M3,6h18v2H3V6z M3,11h18v2H3v-2z M3,16h18v2H3v-2z"
                                          Fill="{StaticResource BrushNavInactive}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <controls:AppLogoMark LogoHeight="40" LogoMaxWidth="200" ShowTruPrefix="False" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CompanyTitle}" Style="{StaticResource TextPageTitle}" Foreground="{StaticResource BrushAccent}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding StoreDisplayName}" Style="{StaticResource TextBody}" FontWeight="SemiBold" Margin="0,2,0,0"
                                       Visibility="{Binding ShowCompactHeaderDetails, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding TillDisplayLine}" Style="{StaticResource TextCaption}" Margin="0,2,0,0"
                                       Visibility="{Binding ShowCompactHeaderDetails, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="{Binding CurrentPageLabel}"
                               Style="{StaticResource TextBody}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextMuted}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <WrapPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Border Style="{StaticResource UserBadge}" Margin="0,0,8,4" VerticalAlignment="Center"
                                ToolTip="{Binding MongoHealthStatusChip}">
                            <TextBlock Text="{Binding MongoHealthStatusChip}" Style="{StaticResource TextCaption}"
                                       FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}"
                                       VerticalAlignment="Center" Margin="8,4"/>
                        </Border>
                        <Border Style="{StaticResource UserBadge}" Margin="0,0,8,4" VerticalAlignment="Center"
                                ToolTip="Business day status — click to open Day Close">
                            <Button Style="{StaticResource GhostNavButton}" Padding="8,4"
                                    Command="{Binding NavigateDayCloseCommand}">
                                <TextBlock Text="{Binding DaySessionStatusChip}" Style="{StaticResource TextCaption}"
                                           FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}"/>
                            </Button>
                        </Border>
                        <Border Style="{StaticResource UserBadge}" Margin="0,0,4,4" VerticalAlignment="Center" ToolTip="Logged in user">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12,12c2.21,0 4,-1.79 4,-4s-1.79,-4 -4,-4 -4,1.79 -4,4 1.79,4 4,4z M12,14c-2.67,0 -8,1.34 -8,4v2h16v-2c0,-2.66 -5.33,-4 -8,-4z"
                                              Fill="{StaticResource BrushAccent}"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{Binding LoggedInUserName}" Style="{StaticResource TextCaption}"
                                           FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Button Width="36" Height="36" Style="{StaticResource GhostNavButton}"
                                Command="{Binding LogoutCommand}"
                                ToolTip="Sign out and return to login"
                                Margin="0,0,4,4">
                            <Viewbox Width="18" Height="18" Stretch="Uniform">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M17,7l-1.41,1.41L18.17,11H8v2h10.17l-2.58,2.58L17,17l5,-5z M4,5h8V3H4c-1.1,0 -2,0.9 -2,2v14c0,1.1 0.9,2 2,2h8v-2H4V5z"
                                          Fill="{StaticResource BrushNavInactive}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Width="36" Height="36" Style="{StaticResource GhostNavButton}"
                                Command="{Binding OpenNotificationsCommand}"
                                ToolTip="{Binding NotificationBellToolTip}"
                                Opacity="{Binding NotificationBellOpacity}"
                                Margin="0,0,4,4">
                            <Viewbox Width="18" Height="18" Stretch="Uniform">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12,22c1.1,0 2,-0.9 2,-2h-4c0,1.1 0.9,2 2,2z M18,16v-5c0,-3.07 -1.63,-5.64 -4.5,-6.32V4c0,-0.83 -0.67,-1.5 -1.5,-1.5s-1.5,0.67 -1.5,1.5v0.68C7.64,5.36 6,7.92 6,11v5l-2,2v1h16v-1l-2,-2z"
                                          Fill="{StaticResource BrushNavInactive}"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button Width="36" Height="36" Style="{StaticResource GhostNavButton}" ToolTip="Settings"
                                Command="{Binding NavigateCommand}"
                                CommandParameter="{x:Static vm:ShellPage.Settings}"
                                Visibility="{Binding ShowSettingsNav, Converter={StaticResource BoolToVis}}"
                                Margin="0,0,0,4">
                            <Viewbox Width="18" Height="18" Stretch="Uniform">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M19.14,12.94c0.04,-0.31 0.06,-0.63 0.06,-0.94c0,-0.31 -0.02,-0.63 -0.06,-0.94l2.03,-1.58c0.18,-0.14 0.23,-0.41 0.12,-0.61l-1.92,-3.32c-0.12,-0.22 -0.37,-0.29 -0.59,-0.22l-2.39,0.96c-0.5,-0.38 -1.03,-0.7 -1.62,-0.94L14.4,2.81c-0.04,-0.24 -0.24,-0.41 -0.48,-0.41h-3.84c-0.24,0 -0.43,0.17 -0.47,0.41L9.25,5.35C8.66,5.59 8.12,5.92 7.63,6.29L5.24,5.33c-0.22,-0.08 -0.47,0 -0.59,0.22L2.74,8.87C2.62,9.08 2.66,9.34 2.86,9.48l2.03,1.58C4.84,11.37 4.8,11.69 4.8,12s0.02,0.63 0.06,0.94l-2.03,1.58c-0.18,0.14 -0.23,0.41 -0.12,0.61l1.92,3.32c0.12,0.22 0.37,0.29 0.59,0.22l2.39,-0.96c0.5,0.38 1.03,0.7 1.62,0.94l0.36,2.54c0.05,0.24 0.24,0.41 0.48,0.41h3.84c0.24,0 0.44,-0.17 0.47,-0.41l0.36,-2.54c0.59,-0.24 1.13,-0.56 1.62,-0.94l2.39,0.96c0.22,0.08 0.47,0 0.59,-0.22l1.92,-3.32c0.12,-0.22 0.07,-0.47 -0.12,-0.61L19.14,12.94z M12,15.6c-1.98,0 -3.6,-1.62 -3.6,-3.6s1.62,-3.6 3.6,-3.6s3.6,1.62 3.6,3.6S13.98,15.6 12,15.6z">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Fill" Value="{StaticResource BrushNavInactive}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSettingsPage}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource BrushAccent}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </WrapPanel>
                </Grid>

        </Border>

        <Grid Grid.Row="1" Margin="12,8,12,8">
            <Grid Visibility="{Binding IsBillingPage, Converter={StaticResource BoolToVis}}">
                <views:BillingView DataContext="{Binding Billing}"/>
            </Grid>
            <Grid Visibility="{Binding IsBarcodesPage, Converter={StaticResource BoolToVis}}">
                <views:BarcodePrintingView DataContext="{Binding BarcodePrinting}"/>
            </Grid>
            <Grid Visibility="{Binding IsDashboardPage, Converter={StaticResource BoolToVis}}">
                <views:DashboardView DataContext="{Binding Dashboard}"/>
            </Grid>
            <Grid Visibility="{Binding IsAnalyticsPage, Converter={StaticResource BoolToVis}}">
                <views:AnalyticsView DataContext="{Binding Analytics}"/>
            </Grid>
            <Grid Visibility="{Binding IsOnlineSalesPage, Converter={StaticResource BoolToVis}}">
                <views:OnlineSalesView DataContext="{Binding OnlineSales}"/>
            </Grid>
            <Grid Visibility="{Binding IsQuotationPage, Converter={StaticResource BoolToVis}}">
                <views:QuotationView DataContext="{Binding Quotation}"/>
            </Grid>
            <Grid Visibility="{Binding IsQuotationManagementPage, Converter={StaticResource BoolToVis}}">
                <views:QuotationManagementView DataContext="{Binding QuotationManagement}"/>
            </Grid>
            <Grid Visibility="{Binding IsCreditBillsPage, Converter={StaticResource BoolToVis}}">
                <views:CreditBillsView DataContext="{Binding CreditBills}"/>
            </Grid>
            <Grid Visibility="{Binding IsCustomersPage, Converter={StaticResource BoolToVis}}">
                <views:CustomersView DataContext="{Binding Customers}"/>
            </Grid>
            <Grid Visibility="{Binding IsSalesmenPage, Converter={StaticResource BoolToVis}}">
                <views:SalesmanView DataContext="{Binding Salesmen}"/>
            </Grid>
            <Grid Visibility="{Binding IsLedgerPage, Converter={StaticResource BoolToVis}}">
                <views:LedgerView DataContext="{Binding Ledger}"/>
            </Grid>
            <Grid Visibility="{Binding IsSaleReturnPage, Converter={StaticResource BoolToVis}}">
                <views:SaleReturnView DataContext="{Binding SaleReturn}"/>
            </Grid>
            <Grid Visibility="{Binding IsBillLookupPage, Converter={StaticResource BoolToVis}}">
                <views:BillLookupView DataContext="{Binding BillLookup}"/>
            </Grid>
            <Grid Visibility="{Binding IsDuplicateBillPage, Converter={StaticResource BoolToVis}}">
                <views:DuplicateBillView DataContext="{Binding DuplicatePrint}"/>
            </Grid>
            <Grid Visibility="{Binding IsAdjustmentsPage, Converter={StaticResource BoolToVis}}">
                <views:AdjustmentBillView DataContext="{Binding AdjustmentBill}"/>
            </Grid>
            <Grid Visibility="{Binding IsDayClosePage, Converter={StaticResource BoolToVis}}">
                <views:DayCloseView DataContext="{Binding DayClose}"/>
            </Grid>
            <Grid Visibility="{Binding IsDailyExpensesPage, Converter={StaticResource BoolToVis}}">
                <views:DailyExpenseView DataContext="{Binding DailyExpenses}"/>
            </Grid>
            <Grid Visibility="{Binding IsSettingsPage, Converter={StaticResource BoolToVis}}">
                <views:SettingsView DataContext="{Binding Settings}"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource BrushFooterBar}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0" Padding="10,8">
            <WrapPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Billing" Style="{StaticResource TextCaption}" VerticalAlignment="Center" Margin="0,0,6,4" FontWeight="SemiBold"/>
                <Button Style="{StaticResource ShortcutChip}" Content="F1 Help" Command="{Binding ShowHelpCommand}" Margin="0,0,4,4"/>
                <Button Style="{StaticResource ShortcutChip}" Content="F2 New" Command="{Binding ClearForNewBillCommand}" Margin="0,0,4,4"/>
                <Button Style="{StaticResource ShortcutChip}" Content="F3 Search" Command="{Binding FocusGlobalSearchCommand}" Margin="0,0,4,4"/>
                <Button Style="{StaticResource ShortcutChip}" Content="F8 Hold" Command="{Binding HoldBillCommand}" Margin="0,0,4,4"/>
                <Rectangle Width="1" Height="24" Fill="{StaticResource BrushBorder}" Margin="4,0,8,4"/>
                <Button Style="{StaticResource PrimaryButton}" Padding="20,10" Margin="0,0,4,4" Content="F9 Post bill" Command="{Binding PostBillCommand}"/>
                <Button Style="{StaticResource ShortcutChip}" Content="F10 Print" Command="{Binding PrintStubCommand}" Margin="0,0,4,4"/>
                <Rectangle Width="1" Height="24" Fill="{StaticResource BrushBorder}" Margin="4,0,8,4"/>
                <Button Style="{StaticResource ShortcutChip}" Content="F11 Duplicate" Command="{Binding OpenDuplicateBillCommand}" Margin="0,0,4,4"/>
                <Button Style="{StaticResource ShortcutChip}" Content="F12 Close" Command="{Binding CloseAppCommand}" Margin="0,0,4,4"/>
            </WrapPanel>
        </Border>

        <Border Grid.RowSpan="3"
                Panel.ZIndex="100"
                Background="#66000000"
                Visibility="{Binding IsNavDrawerOpen, Converter={StaticResource BoolToVis}}"
                MouseLeftButtonDown="NavDrawerOverlay_MouseLeftButtonDown"/>

        <Border Grid.RowSpan="3"
                Panel.ZIndex="101"
                HorizontalAlignment="Left"
                Width="280"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,0,1,0"
                Effect="{StaticResource CardShadowEffect}"
                Visibility="{Binding IsNavDrawerOpen, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource BrushSidebarTint}"
                        BorderBrush="{StaticResource BrushBorder}"
                        BorderThickness="0,0,0,1"
                        Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Navigation"
                                   Style="{StaticResource TextBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushAccent}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Width="32" Height="32"
                                Style="{StaticResource GhostNavButton}"
                                Command="{Binding CloseNavDrawerCommand}"
                                ToolTip="Close menu">
                            <TextBlock Text="✕" FontSize="14" Foreground="{StaticResource BrushNavInactive}"/>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,8,0,8">
                        <controls:NavDrawerItem Label="Billing" Page="{x:Static vm:ShellPage.Billing}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.Billing}}"/>
                        <controls:NavDrawerItem Label="Quotations" Page="{x:Static vm:ShellPage.QuotationManagement}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.QuotationManagement}}"/>
                        <controls:NavDrawerItem Label="Barcodes" Page="{x:Static vm:ShellPage.Barcodes}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.Barcodes}}"/>
                        <controls:NavDrawerItem Label="Dashboard" Page="{x:Static vm:ShellPage.Dashboard}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                Visibility="{Binding ShowDashboardNav, Converter={StaticResource BoolToVis}}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.Dashboard}}"/>
                        <controls:NavDrawerItem Label="Analytics" Page="{x:Static vm:ShellPage.Analytics}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                Visibility="{Binding ShowAnalyticsNav, Converter={StaticResource BoolToVis}}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.Analytics}}"/>
                        <controls:NavDrawerItem Label="Online Sales" Page="{x:Static vm:ShellPage.OnlineSales}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                Visibility="{Binding ShowOnlineSalesNav, Converter={StaticResource BoolToVis}}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.OnlineSales}}"/>
                        <controls:NavDrawerItem Label="Credit Bills" Page="{x:Static vm:ShellPage.CreditBills}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                Visibility="{Binding ShowCreditBillsNav, Converter={StaticResource BoolToVis}}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.CreditBills}}"/>
                        <controls:NavDrawerItem Label="Customers" Page="{x:Static vm:ShellPage.Customers}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.Customers}}"/>
                        <controls:NavDrawerItem Label="Salesman" Page="{x:Static vm:ShellPage.Salesmen}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.Salesmen}}"/>
                        <controls:NavDrawerItem Label="Ledger" Page="{x:Static vm:ShellPage.Ledger}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                Visibility="{Binding ShowLedgerNav, Converter={StaticResource BoolToVis}}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.Ledger}}"/>
                        <controls:NavDrawerItem Label="Returns" Page="{x:Static vm:ShellPage.SaleReturn}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.SaleReturn}}"/>
                        <controls:NavDrawerItem Label="Bill Lookup" Page="{x:Static vm:ShellPage.BillLookup}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.BillLookup}}"/>
                        <controls:NavDrawerItem Label="Day Close" Page="{x:Static vm:ShellPage.DayClose}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.DayClose}}"/>
                        <controls:NavDrawerItem Label="Duplicate" Page="{x:Static vm:ShellPage.DuplicateBill}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.DuplicateBill}}"/>
                        <controls:NavDrawerItem Label="Adjustments" Page="{x:Static vm:ShellPage.Adjustments}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.Adjustments}}"/>
                        <controls:NavDrawerItem Label="Expenses" Page="{x:Static vm:ShellPage.DailyExpenses}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                Visibility="{Binding ShowLedgerNav, Converter={StaticResource BoolToVis}}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.DailyExpenses}}"/>
                        <controls:NavDrawerItem Label="Settings" Page="{x:Static vm:ShellPage.Settings}"
                                                NavigateCommand="{Binding NavigateCommand}"
                                                Visibility="{Binding ShowSettingsNav, Converter={StaticResource BoolToVis}}"
                                                IsActive="{Binding CurrentPage, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static vm:ShellPage.Settings}}"/>
                        <Button HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Command="{Binding LogoutCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                Cursor="Hand"
                                FocusVisualStyle="{x:Null}"
                                ToolTip="Sign out and return to login">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Root"
                                            Background="Transparent"
                                            Padding="16,12"
                                            BorderThickness="3,0,0,0"
                                            BorderBrush="Transparent">
                                        <TextBlock Text="Logout"
                                                   FontFamily="{StaticResource FontFamilyPrimary}"
                                                   FontSize="14"
                                                   Foreground="{StaticResource BrushNavInactive}"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushAccentSoft}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
