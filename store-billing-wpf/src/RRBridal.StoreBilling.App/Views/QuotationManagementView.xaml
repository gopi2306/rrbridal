<UserControl x:Class="RRBridal.StoreBilling.App.Views.QuotationManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Quotations" Style="{StaticResource TextPageTitle}" Foreground="{StaticResource BrushAccent}"/>
                <TextBlock Text="Filter by quotation no, customer name, or mobile. Open to edit or convert to billing."
                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="Refresh" Style="{StaticResource OutlineButton}" MinWidth="96" Height="36" Margin="0,0,8,0"
                        Command="{Binding RefreshCommand}"/>
                <Button Content="+ Create quotation" Style="{StaticResource PrimaryButton}" MinWidth="150" Height="36"
                        Command="{Binding NewQuotationCommand}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Quotation no" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource RoundedTextBox}"
                             Text="{Binding SearchQuotationNo, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Customer name" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource RoundedTextBox}"
                             Text="{Binding SearchCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Mobile" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource RoundedTextBox}"
                             Text="{Binding SearchCustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Search" Style="{StaticResource PrimaryButton}" MinWidth="96" Height="34" Margin="0,0,8,0"
                            Command="{Binding SearchCommand}"/>
                    <Button Content="Clear" Style="{StaticResource OutlineButton}" MinWidth="80" Height="34"
                            Command="{Binding ClearFiltersAndSearchCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="8">
            <DataGrid ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedQuotation}"
                      Style="{StaticResource ThemedDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Quotation no" Binding="{Binding QuotationNo}" Width="150"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding QuotationDate}" Width="100"/>
                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                    <DataGridTextColumn Header="Mobile" Binding="{Binding CustomerPhone}" Width="110"/>
                    <DataGridTextColumn Header="Payable" Binding="{Binding Payable, StringFormat=₹ {0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="88"/>
                    <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="72"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="14,12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Open" Style="{StaticResource OutlineButton}" MinWidth="96" Height="36" Margin="0,0,8,0"
                            Command="{Binding OpenSelectedCommand}"/>
                    <Button Content="Convert to billing" Style="{StaticResource PrimaryButton}" MinWidth="150" Height="36" Margin="0,0,8,0"
                            Command="{Binding ConvertToBillingCommand}"/>
                    <Button Content="Cancel" Style="{StaticResource OutlineButton}" MinWidth="96" Height="36"
                            Command="{Binding CancelSelectedCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
