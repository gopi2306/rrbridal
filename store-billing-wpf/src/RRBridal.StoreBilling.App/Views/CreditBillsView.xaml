<UserControl x:Class="RRBridal.StoreBilling.App.Views.CreditBillsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Credit bills" Style="{StaticResource TextPageTitle}" Foreground="{StaticResource BrushAccent}"/>
                <TextBlock Text="Pay-later bills — record partial or full balance payments. Each payment prints a receipt."
                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh" Style="{StaticResource OutlineButton}" MinWidth="96" Height="36" VerticalAlignment="Top"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <UniformGrid Grid.Row="1" Margin="0,0,0,12"
                     ui:UniformGridColumnsBehavior.IsEnabled="True"
                     ui:UniformGridColumnsBehavior.CompactColumns="1"
                     ui:UniformGridColumnsBehavior.MediumColumns="2"
                     ui:UniformGridColumnsBehavior.WideColumns="2">
            <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0" BorderBrush="{StaticResource BrushAccent}">
                <StackPanel>
                    <TextBlock Text="Pending balance" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding BalanceTillSummary}" FontSize="20" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}" Margin="6,0,0,0" Padding="14,12">
                <StackPanel>
                    <TextBlock Text="Open credit bills" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding PendingCountSummary}" FontSize="20" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Bill no" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource RoundedTextBox}"
                             Text="{Binding SearchBillNo, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Customer name" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource RoundedTextBox}"
                             Text="{Binding SearchCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Mobile" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource RoundedTextBox}"
                             Text="{Binding SearchCustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="Status" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox Style="{StaticResource RoundedComboBox}"
                              ItemsSource="{Binding StatusFilterOptions}"
                              SelectedItem="{Binding SelectedStatusFilter}"/>
                </StackPanel>
                <StackPanel Grid.Column="8" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Search" Style="{StaticResource PrimaryButton}" MinWidth="96" Height="34" Margin="0,0,8,0"
                            Command="{Binding SearchCommand}"/>
                    <Button Content="Clear" Style="{StaticResource OutlineButton}" MinWidth="80" Height="34"
                            Command="{Binding ClearFiltersAndSearchCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="8">
            <DataGrid ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedBill}"
                      Style="{StaticResource ThemedDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="130"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding BillDate}" Width="96"/>
                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                    <DataGridTextColumn Header="Mobile" Binding="{Binding CustomerPhone}" Width="108"/>
                    <DataGridTextColumn Header="Payable" Binding="{Binding TotalPayable, StringFormat=₹ {0:N2}}" Width="96"/>
                    <DataGridTextColumn Header="Advance" Binding="{Binding AdvancePaid, StringFormat=₹ {0:N2}}" Width="88"/>
                    <DataGridTextColumn Header="Paid" Binding="{Binding AmountPaid, StringFormat=₹ {0:N2}}" Width="88"/>
                    <DataGridTextColumn Header="Balance" Binding="{Binding BalanceDue, StringFormat=₹ {0:N2}}" Width="96"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="76"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="14,12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0"/>
                <Button Grid.Column="1" Content="Receipt" Style="{StaticResource PrimaryButton}"
                        MinWidth="160" Height="38" Padding="20,0"
                        Command="{Binding RecordPaymentCommand}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
