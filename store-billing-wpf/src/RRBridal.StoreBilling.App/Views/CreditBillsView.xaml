<UserControl x:Class="RRBridal.StoreBilling.App.Views.CreditBillsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BrushBackground}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,0,8">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Credit bills" Style="{StaticResource TextPageTitle}" Foreground="{StaticResource BrushAccent}"/>
            <TextBlock Text="Pay-later bills — record advance remaining as partial or full payments; each payment prints a receipt."
                       Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Margin="0,0,0,12"
                     ui:UniformGridColumnsBehavior.IsEnabled="True"
                     ui:UniformGridColumnsBehavior.CompactColumns="1"
                     ui:UniformGridColumnsBehavior.MediumColumns="2"
                     ui:UniformGridColumnsBehavior.WideColumns="2">
            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" BorderBrush="{StaticResource BrushAccent}">
                <StackPanel>
                    <TextBlock Text="Pending balance" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding BalanceTillSummary}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="Open credit bills" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                    <TextBlock Text="{Binding PendingCountSummary}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,12">
            <WrapPanel>
                <StackPanel Width="160" Margin="0,0,8,8">
                    <TextBlock Text="Bill no" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Margin="0,4,0,0"
                             Text="{Binding SearchBillNo, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Width="180" Margin="0,0,8,8">
                    <TextBlock Text="Customer name" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Margin="0,4,0,0"
                             Text="{Binding SearchCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Width="140" Margin="0,0,8,8">
                    <TextBlock Text="Mobile" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Margin="0,4,0,0"
                             Text="{Binding SearchCustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Width="120" Margin="0,0,8,8">
                    <TextBlock Text="Status" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <ComboBox Style="{StaticResource RoundedComboBox}" Margin="0,4,0,0"
                              ItemsSource="{Binding StatusFilterOptions}"
                              SelectedItem="{Binding SelectedStatusFilter}"/>
                </StackPanel>
                <Button Content="Search" Style="{StaticResource PrimaryButton}" Width="90" VerticalAlignment="Bottom"
                        Margin="0,0,8,8" Command="{Binding SearchCommand}"/>
                <Button Content="Refresh" Style="{StaticResource OutlineButton}" Width="90" VerticalAlignment="Bottom"
                        Margin="0,0,0,8" Command="{Binding RefreshCommand}"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="8">
            <DataGrid ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedBill}"
                      Style="{StaticResource ThemedDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="140"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding BillDate}" Width="100"/>
                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                    <DataGridTextColumn Header="Mobile" Binding="{Binding CustomerPhone}" Width="110"/>
                    <DataGridTextColumn Header="Payable" Binding="{Binding TotalPayable, StringFormat=₹ {0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="Advance" Binding="{Binding AdvancePaid, StringFormat=₹ {0:N2}}" Width="90"/>
                    <DataGridTextColumn Header="Paid" Binding="{Binding AmountPaid, StringFormat=₹ {0:N2}}" Width="90"/>
                    <DataGridTextColumn Header="Balance" Binding="{Binding BalanceDue, StringFormat=₹ {0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <Button Content="Record payment" Style="{StaticResource PrimaryButton}"
                    MinWidth="160" Padding="20,10" HorizontalAlignment="Center"
                    Command="{Binding RecordPaymentCommand}"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</UserControl>
