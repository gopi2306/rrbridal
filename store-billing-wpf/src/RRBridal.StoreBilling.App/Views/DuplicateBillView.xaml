<UserControl x:Class="RRBridal.StoreBilling.App.Views.DuplicateBillView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="320"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Duplicate print" Style="{StaticResource TextPageTitleAccent}"/>
            <TextBlock Text="Reprint a posted bill or credit note with DUPLICATE watermark. Does not change stock or totals."
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <TabControl Grid.Row="1" Style="{StaticResource ThemedTabControl}" VerticalAlignment="Stretch">
            <TabItem Header="Bill">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource FilterBarCard}" Margin="0,0,0,12">
                        <WrapPanel DataContext="{Binding Bill}" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <StackPanel Width="150" Margin="0,0,12,0">
                                <TextBlock Text="Invoice no" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SearchInvoiceNo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Width="160" Margin="0,0,12,0">
                                <TextBlock Text="Customer name" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SearchCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Width="140" Margin="0,0,12,0">
                                <TextBlock Text="Date from" Style="{StaticResource FilterFieldLabel}"/>
                                <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding SearchDateFrom}"/>
                            </StackPanel>
                            <StackPanel Width="140" Margin="0,0,12,0">
                                <TextBlock Text="Date to" Style="{StaticResource FilterFieldLabel}"/>
                                <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding SearchDateTo}"/>
                            </StackPanel>
                            <Button Content="Search" Style="{StaticResource PrimaryButton}"
                                    VerticalAlignment="Bottom" Width="88" Height="32"
                                    Command="{Binding SearchCommand}"/>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1" DataContext="{Binding Bill}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,8,0">
                            <DataGrid ItemsSource="{Binding Results}"
                                      SelectedItem="{Binding SelectedBill}"
                                      Style="{StaticResource ThemedDataGrid}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="120"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding BillDate}" Width="100"/>
                                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                                    <DataGridTextColumn Header="Payable" Binding="{Binding Payable, StringFormat=₹ {0:N2}}" Width="100"/>
                                    <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Bill details" Style="{StaticResource TextSectionTitle}"/>
                                <TextBlock Text="{Binding DetailText}" Margin="0,8,0,16" TextWrapping="Wrap" Foreground="{StaticResource BrushText}"/>
                                <Button Content="Print duplicate copy" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding PrintDuplicateCommand}" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>
                                <Button Content="Send WhatsApp bill" Style="{StaticResource OutlineButton}"
                                        Command="{Binding SendWhatsAppCommand}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="{Binding Bill.StatusMessage}" Margin="0,12,0,0"
                               Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>

            <TabItem Header="Credit Note">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource FilterBarCard}" Margin="0,0,0,12">
                        <WrapPanel DataContext="{Binding CreditNote}" Orientation="Horizontal" VerticalAlignment="Bottom">
                            <StackPanel Width="150" Margin="0,0,12,8">
                                <TextBlock Text="Original bill no" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SearchOriginalBillNo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Width="150" Margin="0,0,12,8">
                                <TextBlock Text="Return bill no" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SearchReturnNo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Width="160" Margin="0,0,12,8">
                                <TextBlock Text="Customer name" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SearchCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Width="130" Margin="0,0,12,8">
                                <TextBlock Text="Mobile no" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SearchMobileNo, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Width="140" Margin="0,0,12,8">
                                <TextBlock Text="Date from" Style="{StaticResource FilterFieldLabel}"/>
                                <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding SearchDateFrom}"/>
                            </StackPanel>
                            <StackPanel Width="140" Margin="0,0,12,8">
                                <TextBlock Text="Date to" Style="{StaticResource FilterFieldLabel}"/>
                                <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding SearchDateTo}"/>
                            </StackPanel>
                            <Button Content="Search" Style="{StaticResource PrimaryButton}"
                                    VerticalAlignment="Bottom" Width="88" Height="32" Margin="0,0,0,8"
                                    Command="{Binding SearchCommand}"/>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1" DataContext="{Binding CreditNote}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,8,0">
                            <DataGrid ItemsSource="{Binding Results}"
                                      SelectedItem="{Binding SelectedCreditNote}"
                                      Style="{StaticResource ThemedDataGrid}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Credit note no" Binding="{Binding CreditNoteNo}" Width="130"/>
                                    <DataGridTextColumn Header="Return no" Binding="{Binding ReturnNo}" Width="120"/>
                                    <DataGridTextColumn Header="Original bill" Binding="{Binding OriginalBillNo}" Width="120"/>
                                    <DataGridTextColumn Header="Date" Binding="{Binding CreatedAtDisplay}" Width="100"/>
                                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=₹ {0:N2}}" Width="100"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Credit note details" Style="{StaticResource TextSectionTitle}"/>
                                <TextBlock Text="{Binding DetailText}" Margin="0,8,0,16" TextWrapping="Wrap" Foreground="{StaticResource BrushText}"/>
                                <Button Content="Print duplicate copy" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding PrintDuplicateCommand}" HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="{Binding CreditNote.StatusMessage}" Margin="0,12,0,0"
                               Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
