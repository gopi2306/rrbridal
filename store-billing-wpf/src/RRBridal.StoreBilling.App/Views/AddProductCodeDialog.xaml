<Window x:Class="RRBridal.StoreBilling.App.Views.AddProductCodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add product"
        Width="420"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{StaticResource BrushBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Enter product code (SKU or barcode)" FontWeight="SemiBold" Foreground="{StaticResource BrushText}"/>

        <StackPanel Grid.Row="1" Margin="0,12,0,16">
            <TextBlock Text="Product code" FontSize="11" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,4"/>
            <TextBox x:Name="ProductCodeBox" Style="{StaticResource RoundedTextBox}"
                     KeyDown="ProductCodeBox_OnKeyDown"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Width="90" Margin="0,0,8,0"
                    IsCancel="True" Click="Cancel_OnClick"/>
            <Button Content="Add" Style="{StaticResource PrimaryButton}" Width="90"
                    IsDefault="True" Click="Add_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
