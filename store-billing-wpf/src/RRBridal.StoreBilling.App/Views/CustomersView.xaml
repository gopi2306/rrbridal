<UserControl x:Class="RRBridal.StoreBilling.App.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Customers" Style="{StaticResource TextPageTitle}" Foreground="{StaticResource BrushAccent}"/>
                <TextBlock Text="Browse registered customers, view details, register new customers, or apply a customer to billing."
                           Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
            <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Content="New customer" Style="{StaticResource OutlineButton}" MinWidth="120" Margin="0,0,10,4"
                        Command="{Binding NewCustomerCommand}"/>
                <Button Content="Save (F4)" Style="{StaticResource PrimaryButton}" MinWidth="110" Margin="0,0,10,4"
                        Command="{Binding SaveCommand}"/>
                <Button Content="Use in billing" Style="{StaticResource PrimaryButton}" MinWidth="130" Margin="0,0,0,4"
                        Command="{Binding UseInBillingCommand}"/>
            </WrapPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,12">
            <WrapPanel>
                <StackPanel Width="160" Margin="0,0,8,8">
                    <TextBlock Text="Customer code" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Margin="0,4,0,0"
                             Text="{Binding SearchCustomerCode, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Width="200" Margin="0,0,8,8">
                    <TextBlock Text="Customer name" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Margin="0,4,0,0"
                             Text="{Binding SearchCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Width="160" Margin="0,0,8,8">
                    <TextBlock Text="Mobile" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Margin="0,4,0,0"
                             Text="{Binding SearchCustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <Button Content="Search" Style="{StaticResource PrimaryButton}" Width="100" VerticalAlignment="Bottom"
                        Margin="0,0,8,8" Command="{Binding SearchCommand}"/>
                <Button Content="Refresh" Style="{StaticResource OutlineButton}" Width="90" VerticalAlignment="Bottom"
                        Margin="0,0,0,8" Command="{Binding RefreshCommand}"/>
            </WrapPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="8">
                <DataGrid ItemsSource="{Binding Results}"
                          SelectedItem="{Binding SelectedCustomer}"
                          Style="{StaticResource ThemedDataGrid}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Code" Binding="{Binding CustomerCode}" Width="100"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Mobile" Binding="{Binding Phone}" Width="110"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="140"/>
                        <DataGridCheckBoxColumn Header="Credit" Binding="{Binding IsCreditCustomer}" Width="60"/>
                        <DataGridTextColumn Header="Sync" Binding="{Binding SyncStatus}" Width="70"/>
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Customer details" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding DetailSourceLabel}" FontSize="11" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,12"/>

                        <TextBlock Text="CUSTOMER CODE" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding CustomerCode, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True" Margin="0,0,0,10"/>

                        <TextBlock Text="CUSTOMER NAME *" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,10"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TELEPHONE" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsDetailReadOnly}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="MOBILE *" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Mobile, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsDetailReadOnly}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="EMAIL" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,10"/>

                        <TextBlock Text="GSTIN" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Gstin, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,10"/>

                        <TextBlock Text="ADDRESS" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding DoorNo, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,6" ToolTip="Door / plot no"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Street, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,6" ToolTip="Street"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding FullAddress, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,10" ToolTip="Full address"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CITY" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsDetailReadOnly}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="PINCODE" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Pincode, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsDetailReadOnly}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="STATE" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,10"/>

                        <CheckBox Content="Credit customer (eligible for bill on credit)"
                                  IsChecked="{Binding IsCreditCustomer}"
                                  IsEnabled="{Binding IsDetailReadOnly, Converter={StaticResource InvertBool}}"
                                  Margin="0,0,0,10"/>

                        <TextBlock Text="CENTRAL SYNC" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SyncStatus, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}"
                   HorizontalAlignment="Center" Margin="0,12,0,0" TextWrapping="Wrap"/>
    </Grid>
</UserControl>
