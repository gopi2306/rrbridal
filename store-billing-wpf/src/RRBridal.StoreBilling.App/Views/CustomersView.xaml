<UserControl x:Class="RRBridal.StoreBilling.App.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1100"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock Text="Customers" Style="{StaticResource TextPageTitleAccent}"/>
                <TextBlock Text="Browse, register, and manage customers. Mark credit customers for pay-later billing."
                           Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Content="New customer" Style="{StaticResource OutlineButton}" MinWidth="120" Margin="0,0,8,0"
                        Command="{Binding NewCustomerCommand}"/>
                <Button Content="Save (F4)" Style="{StaticResource PrimaryButton}" MinWidth="100" Margin="0,0,8,0"
                        Command="{Binding SaveCommand}"/>
                <Button Content="Use in billing" Style="{StaticResource PrimaryButton}" MinWidth="120"
                        Command="{Binding UseInBillingCommand}"/>
            </StackPanel>
        </Grid>

        <!-- Summary strip -->
        <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,12">
            <Border Style="{StaticResource MetricCardAccent}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="Search results" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding ResultsCountSummary}" Style="{StaticResource MetricValueAccent}" FontSize="18"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}" Margin="6,0,0,0" Padding="14,12">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}"
                           VerticalAlignment="Center" TextWrapping="Wrap"/>
            </Border>
        </UniformGrid>

        <!-- Master / detail -->
        <Grid Grid.Row="2" ui:MasterDetailLayoutBehavior.IsEnabled="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" MinWidth="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- List + search -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="12">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Text="Search customers" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Column="0" Grid.Row="0">
                                <TextBlock Text="Code" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}"
                                         Text="{Binding SearchCustomerCode, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Grid.Row="0">
                                <TextBlock Text="Name" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}"
                                         Text="{Binding SearchCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" Grid.Row="0">
                                <TextBlock Text="Mobile" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}"
                                         Text="{Binding SearchCustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.ColumnSpan="5" Grid.Row="1"
                                        Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="Search" Style="{StaticResource PrimaryButton}" MinWidth="96" Margin="0,0,8,0"
                                        Command="{Binding SearchCommand}"/>
                                <Button Content="Refresh" Style="{StaticResource OutlineButton}" MinWidth="96"
                                        Command="{Binding RefreshCommand}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <DataGrid ItemsSource="{Binding Results}"
                              SelectedItem="{Binding SelectedCustomer}"
                              Style="{StaticResource ThemedDataGrid}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              MinHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding CustomerCode}" Width="88"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Mobile" Binding="{Binding Phone}" Width="108"/>
                            <DataGridCheckBoxColumn Header="Credit" Binding="{Binding IsCreditCustomer}" Width="56"/>
                            <DataGridTextColumn Header="Sync" Binding="{Binding SyncStatus}" Width="64"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Detail panel -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <!-- Empty state -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24"
                                Visibility="{Binding ShowDetailPlaceholder, Converter={StaticResource BoolToVis}}">
                        <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource BrushSidebarTint}"
                                HorizontalAlignment="Center" Margin="0,0,0,14"/>
                        <TextBlock Text="Select a customer" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushAccent}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Choose a row from the list to view and edit details, or click New customer."
                                   Foreground="{StaticResource BrushTextMuted}" FontSize="12" TextWrapping="Wrap"
                                   TextAlignment="Center" MaxWidth="260" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Detail form -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18,16"
                                  Visibility="{Binding ShowDetailForm, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="{Binding DetailPanelTitle}" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushAccent}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding DetailSourceLabel}" FontSize="11"
                                       Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                            <!-- Contact -->
                            <TextBlock Text="Contact" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                    <TextBlock Text="Customer code" Style="{StaticResource FormFieldLabel}"/>
                                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding CustomerCode, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="True"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
                                    <TextBlock Text="Customer name *" Style="{StaticResource FormFieldLabel}"/>
                                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding IsDetailReadOnly}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="Telephone" Style="{StaticResource FormFieldLabel}"/>
                                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Telephone, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding IsDetailReadOnly}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="Mobile *" Style="{StaticResource FormFieldLabel}"/>
                                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Mobile, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding IsDetailReadOnly}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                                    <TextBlock Text="Email" Style="{StaticResource FormFieldLabel}"/>
                                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding IsDetailReadOnly}"/>
                                </StackPanel>
                            </Grid>

                            <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0" Margin="0,0,0,14"/>

                            <!-- Address -->
                            <TextBlock Text="Address &amp; tax" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,10"/>
                            <StackPanel Margin="0,0,0,14">
                                <TextBlock Text="GSTIN" Style="{StaticResource FormFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Gstin, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,10"/>
                                <TextBlock Text="Door / plot" Style="{StaticResource FormFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding DoorNo, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,8"/>
                                <TextBlock Text="Street" Style="{StaticResource FormFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Street, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,8"/>
                                <TextBlock Text="Full address" Style="{StaticResource FormFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding FullAddress, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsDetailReadOnly}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="City" Style="{StaticResource FormFieldLabel}"/>
                                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="{Binding IsDetailReadOnly}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Pincode" Style="{StaticResource FormFieldLabel}"/>
                                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Pincode, UpdateSourceTrigger=PropertyChanged}"
                                                 IsReadOnly="{Binding IsDetailReadOnly}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="State" Style="{StaticResource FormFieldLabel}" Margin="0,10,0,4"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="{Binding IsDetailReadOnly}"/>
                            </StackPanel>

                            <Border BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0" Margin="0,0,0,14"/>

                            <!-- Billing options -->
                            <TextBlock Text="Billing options" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,10"/>
                            <Border Background="{StaticResource BrushSidebarTint}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <CheckBox Content="Credit customer — eligible for Bill on credit"
                                          Style="{StaticResource ThemedCheckBox}"
                                          IsChecked="{Binding IsCreditCustomer}"
                                          IsEnabled="{Binding IsDetailReadOnly, Converter={StaticResource InvertBool}}"/>
                            </Border>

                            <StackPanel>
                                <TextBlock Text="Central sync status" Style="{StaticResource FormFieldLabel}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SyncStatus, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="True"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3" Text="Tip: F4 saves · Esc starts new customer form"
                   Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                   HorizontalAlignment="Center" Margin="0,10,0,0"/>
    </Grid>
</UserControl>
