<Window x:Class="RRBridal.StoreBilling.App.Views.AppMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TitleText}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MinWidth="360"
        MaxWidth="480"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        SnapsToDevicePixels="True">
    <Border Background="{StaticResource BrushSurface}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="12"
            Effect="{StaticResource ElevatedShadowEffect}">
        <DockPanel>
            <Border DockPanel.Dock="Top"
                    Background="{StaticResource BrushSidebarTint}"
                    CornerRadius="14,14,0,0"
                    Padding="18,14"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock Text="{Binding TitleText}"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushText}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                    <Button HorizontalAlignment="Right"
                            Width="28" Height="28"
                            Style="{StaticResource GhostNavButton}"
                            Click="Close_Click"
                            ToolTip="Close">
                        <TextBlock Text="✕" FontSize="12" Foreground="{StaticResource BrushTextMuted}"/>
                    </Button>
                </Grid>
            </Border>

            <Border DockPanel.Dock="Bottom"
                    Background="{StaticResource BrushSidebarHeader}"
                    CornerRadius="0,0,14,14"
                    Padding="16,12"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,1,0,0">
                <StackPanel x:Name="ButtonHost" Orientation="Horizontal" HorizontalAlignment="Right"/>
            </Border>

            <Grid Margin="20,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="40" Height="40" CornerRadius="20"
                        VerticalAlignment="Top" Margin="0,0,14,0"
                        Background="{Binding IconBackground}">
                    <TextBlock Text="{Binding IconGlyph}"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{Binding IconForeground}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding MessageText}"
                           TextWrapping="Wrap"
                           FontSize="13.5"
                           LineHeight="20"
                           Foreground="{StaticResource BrushText}"
                           VerticalAlignment="Center"/>
            </Grid>
        </DockPanel>
    </Border>
</Window>
