<Window x:Class="RRBridal.StoreBilling.App.Views.NotificationsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notifications"
        Width="520"
        Height="480"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource TextSectionTitle}" FontSize="18" Text="Pending sync to central" TextWrapping="Wrap"/>

        <StackPanel Grid.Row="1" Margin="0,8,0,12">
            <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" Foreground="{StaticResource BrushText}"/>
            <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}"
                       Margin="0,6,0,0" FontSize="12"/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="8">
            <DataGrid ItemsSource="{Binding Items}"
                      Style="{StaticResource ThemedDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="140"/>
                    <DataGridTextColumn Header="When" Binding="{Binding CreatedAtDisplay}" Width="130"/>
                    <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding FooterNote}" TextWrapping="Wrap"
                   Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,8,0,0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Refresh" Style="{StaticResource OutlineButton}" Margin="0,0,8,0"
                    Command="{Binding RefreshCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"/>
            <Button Content="Sync now" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                    Command="{Binding SyncNowCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}"/>
            <Button Content="Close" Style="{StaticResource OutlineButton}" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
