<Window x:Class="RRBridal.StoreBilling.App.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings &amp; sync"
        Width="560"
        Height="860"
        Loaded="SettingsDialog_OnLoaded"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Central connection" Foreground="{StaticResource BrushText}"/>
            <TextBlock Margin="0,4,0,12" Text="Login, sync, and developer test actions." Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap"/>

            <TextBlock Text="Email" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
            <TextBlock Text="Password" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding LoginPassword, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="Login" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0" Command="{Binding LoginCentralCommand}" Width="100"/>
                <Button Content="Logout" Style="{StaticResource OutlineButton}" Command="{Binding LogoutCentralCommand}" Width="100"/>
            </StackPanel>

            <TextBlock Text="{Binding AuthStatusText}" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <Separator Margin="0,8,0,16"/>

            <TextBlock FontWeight="SemiBold" Text="Sync"/>
            <Button Content="Refresh status" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left" Margin="0,8,0,8" Command="{Binding RefreshStatusCommand}"/>
            <TextBlock Text="{Binding PendingOutboxText}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding CursorText}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding LastErrorText, StringFormat=Last error: {0}}" TextWrapping="Wrap" Margin="0,0,0,4"/>
            <TextBlock Text="Sync diagnostics (last pull)" FontWeight="SemiBold" Margin="0,4,0,2"/>
            <TextBlock Text="{Binding SyncDiagnosticsText}" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>
            <TextBlock Text="{Binding AutoSyncStatusText}" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>
            <Button Content="Run sync once" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Command="{Binding RunSyncOnceCommand}" Margin="0,0,0,16"/>

            <Separator Margin="0,8,0,16"/>

            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Invoice / receipt" Foreground="{StaticResource BrushText}"/>
            <TextBlock Margin="0,4,0,6" Text="Printed bill header, footer, print format (thermal, A4, or A5), and separate Windows printers for thermal and A4/A5." Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap"/>
            <TextBlock Margin="0,0,0,12" Text="Saved locally in %LocalAppData%\RRBridal\StoreBilling\receipt_config.json (not store MongoDB). Company profile comes from central database rr_bridal_central."
                       Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" FontSize="11"/>

            <TextBlock Text="Store name" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptStoreName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            <TextBlock Text="Address" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptAddress, UpdateSourceTrigger=PropertyChanged}" MinHeight="48" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>
            <TextBlock Text="Customer care phone" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptCustomerCarePhone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            <TextBlock Text="GSTIN" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptGstin, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            <TextBlock Text="FSSAI no." Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptFssaiNo, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            <TextBlock Text="Branch code" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptBranchCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            <TextBlock Text="Website" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptWebsite, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
            <TextBlock Text="Terms (paragraph)" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptTerms, UpdateSourceTrigger=PropertyChanged}" MinHeight="56" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>
            <TextBlock Text="Policy lines (one per line)" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptPolicyLinesText, UpdateSourceTrigger=PropertyChanged}" MinHeight="56" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,8"/>
            <TextBlock Text="Thank-you line" Margin="0,0,0,4"/>
            <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptThankYouLine, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

            <TextBlock Text="Company master and printer are saved from central only when you use Run sync once (below). Edit fields here and Save receipt settings for local-only changes until the next sync."
                       TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
            <TextBlock Text="{Binding ReceiptCentralSyncText}" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>
            <Button Content="Reload saved receipt settings" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left"
                    Command="{Binding PullReceiptFromCentralCommand}" Margin="0,0,0,12"/>

            <TextBlock FontWeight="SemiBold" Text="Printer" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding ReceiptPrinterHintText}" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding ReceiptPrinterWarningText}" TextWrapping="Wrap" Foreground="#C45A00" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Refresh printer list" Style="{StaticResource OutlineButton}" Command="{Binding RefreshPrintersCommand}" Margin="0,0,8,0"/>
                <CheckBox Content="Always use Windows print dialog" IsChecked="{Binding ReceiptAlwaysUsePrintDialog}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Network printers (e.g. \\pos\Canon…) appear after Refresh. Use the full \\server\name if shown."
                       FontSize="11" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <TextBlock Text="Print format" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <StackPanel Margin="0,0,0,4">
                <RadioButton Content="Thermal receipt (80mm)" GroupName="PrintFormat" Margin="0,0,0,4"
                             IsChecked="{Binding IsThermalReceiptFormat, Mode=TwoWay}"/>
                <RadioButton Content="A4 tax invoice" GroupName="PrintFormat" Margin="0,0,0,4"
                             IsChecked="{Binding IsA4ReceiptFormat, Mode=TwoWay}"/>
                <RadioButton Content="A5 tax invoice" GroupName="PrintFormat"
                             IsChecked="{Binding IsA5ReceiptFormat, Mode=TwoWay}"/>
            </StackPanel>
            <CheckBox Content="Use pre-printed A5 paper (values only)"
                      IsChecked="{Binding A5PrePrintedEnabled}"
                      Visibility="{Binding IsA5ReceiptFormat, Converter={StaticResource BoolToVis}}"
                      Margin="24,0,0,4"/>
            <TextBlock Text="Pre-printed A5: load branded stationery; app prints bill data on the form lines only."
                       Visibility="{Binding IsA5ReceiptFormat, Converter={StaticResource BoolToVis}}"
                       TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                       Margin="24,0,0,8"/>

            <Border Visibility="{Binding IsA5PrePrintedSettingsVisible, Converter={StaticResource BoolToVis}}"
                    Margin="24,0,0,12" Padding="12" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold" Text="A5 pre-printed alignment (mm)" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,8"
                               Text="All fields print by default (BILL TO, INV, DATE, CONTACT, stitching, D/D, lines, total). Saved with Save receipt settings. Uses A4/A5 invoice printer below. Print on PAKEEZA paper to verify."/>

                    <ScrollViewer MaxHeight="480" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Global" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Offset X" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.OffsetXMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Offset Y" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.OffsetYMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Table offset Y" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TableOffsetYMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Baseline nudge" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TextBaselineNudgeMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Row 1 — Bill To / Inv / Date" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="56"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Field" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Top" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Left" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Width" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Bill To" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.BillToTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.BillToLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.BillToWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Inv No" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.InvNoTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.InvNoLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.InvNoWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Date" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.DateTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.DateLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="3" Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.DateWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Row 2 — Contact / stitching / D/D" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88"/>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="64"/>
                                    <ColumnDefinition Width="64"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Field" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Top" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Left" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Width / size" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Contact" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource RoundedTextBox}" MinWidth="56" MinHeight="28"
                                         Text="{Binding A5Layout.MetaRow2TopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource RoundedTextBox}" MinWidth="56" MinHeight="28"
                                         Text="{Binding A5Layout.ContactLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource RoundedTextBox}" MinWidth="56" MinHeight="28"
                                         Text="{Binding A5Layout.ContactWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Stitching tick" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource RoundedTextBox}" MinWidth="56" MinHeight="28"
                                         Text="{Binding A5Layout.StitchingTickTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource RoundedTextBox}" MinWidth="56" MinHeight="28"
                                         Text="{Binding A5Layout.StitchingTickLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="3" Style="{StaticResource RoundedTextBox}" MinWidth="56" MinHeight="28"
                                         Text="{Binding A5Layout.StitchingTickSizeMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="D/D date" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource RoundedTextBox}" MinWidth="56" MinHeight="28"
                                         Text="{Binding A5Layout.DeliveryDateTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource RoundedTextBox}" MinWidth="56" MinHeight="28"
                                         Text="{Binding A5Layout.DeliveryDateLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="3" Grid.Column="3" Style="{StaticResource RoundedTextBox}" MinWidth="56" MinHeight="28"
                                         Text="{Binding A5Layout.DeliveryDateWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Table" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Table top" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TableTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Row height" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.LineRowHeightMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Lines per page" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.MaxLineRows, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Text="Multi-page bills: page 1 shows Total Qty + Continued when more lines follow."
                                           TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="56"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Column" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Left" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Width" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Description" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ColDescLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ColDescWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Qty" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ColQtyLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ColQtyWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Rate" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ColRateLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ColRateWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Amount" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ColAmountLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="4" Grid.Column="2" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ColAmountWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Total" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TotalAmountLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TotalAmountTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TotalAmountWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Total Qty (page 1, multi-page only)" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TotalQtyLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TotalQtyTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Qty width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TotalQtyWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Continued (page 1, multi-page only)" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Label text" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ContinuedLabel, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <TextBlock Text="Row position follows last line + Total Qty. Left/width 0 = use Description column."
                                       FontSize="11" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ContinuedLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.ContinuedWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Discount name (Discount 10%)" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.DiscountPercentLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.DiscountPercentTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Discount name width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.DiscountPercentWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Discount amount" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.DiscountAmountLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.DiscountAmountTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Discount amount width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.DiscountAmountWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Font" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Body pt" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.BodyFontPt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Total pt" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.TotalFontPt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Font family" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource RoundedComboBox}"
                                          ItemsSource="{Binding A5FontFamilyOptions}"
                                          SelectedItem="{Binding A5Layout.PrintFontFamily, Mode=TwoWay}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Bill to max chars" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource RoundedTextBox}" Text="{Binding A5Layout.BillToMaxChars, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Reset to defaults" Style="{StaticResource OutlineButton}"
                                Command="{Binding ResetA5PrePrintedLayoutToDefaultsCommand}" Margin="0,0,8,0"/>
                        <Button Content="Preview test layout" Style="{StaticResource OutlineButton}"
                                Command="{Binding PreviewA5PrePrintedAlignmentCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <CheckBox Content="Also print thermal receipt first (80mm)"
                      IsChecked="{Binding AlsoPrintThermalFirst}"
                      Visibility="{Binding IsOfficeInvoiceFormat, Converter={StaticResource BoolToVis}}"
                      Margin="0,0,0,4"/>
            <TextBlock Text="Prints thermal receipt first (thermal printer), then the A4/A5 invoice (office printer)."
                       Visibility="{Binding IsOfficeInvoiceFormat, Converter={StaticResource BoolToVis}}"
                       TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Thermal: 80mm POS printer. A4/A5: office laser/inkjet — load matching paper in the tray."
                       TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>
            <TextBlock Text="Thermal receipt printer (80mm)" Margin="0,0,0,4"/>
            <ComboBox Style="{StaticResource RoundedComboBox}" ItemsSource="{Binding PrinterOptions}" DisplayMemberPath="Display"
                      SelectedValuePath="FullName" SelectedValue="{Binding SelectedThermalPrinterFullName, Mode=TwoWay}" Margin="0,0,0,8"/>
            <TextBlock Text="A4 / A5 invoice printer" Margin="0,0,0,4"/>
            <ComboBox Style="{StaticResource RoundedComboBox}" ItemsSource="{Binding PrinterOptions}" DisplayMemberPath="Display"
                      SelectedValuePath="FullName" SelectedValue="{Binding SelectedOfficePrinterFullName, Mode=TwoWay}" Margin="0,0,0,8"/>
            <StackPanel Visibility="{Binding IsThermalReceiptFormat, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Receipt width (characters)" Margin="0,0,0,4"/>
                <TextBlock Text="3-inch / 80mm thermal (e.g. TVS RP 3200 Lite): use 48 chars; adjust if text wraps."
                           TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,4"/>
                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding ReceiptCharWidth, UpdateSourceTrigger=PropertyChanged}" Width="80" HorizontalAlignment="Left" Margin="0,0,0,12"/>
            </StackPanel>

            <Button Content="Save receipt settings" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Command="{Binding SaveReceiptSettingsCommand}" Margin="0,0,0,16"/>

            <Separator Margin="0,8,0,16"/>

            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Duplicate bill print" Foreground="{StaticResource BrushText}"/>
            <TextBlock Margin="0,4,0,12" Text="Reprint posted invoices with DUPLICATE watermark (no stock change)." Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap"/>
            <CheckBox Content="Allow duplicate bill print (F11 / Duplicate screen / Ledger)" IsChecked="{Binding BillingAllowDuplicatePrint}" Margin="0,0,0,12"/>
            <Button Content="Save duplicate print setting" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                    Command="{Binding SaveBillingSettingsCommand}" Margin="0,0,0,16"/>

            <Separator Margin="0,8,0,16"/>

            <TextBlock FontWeight="SemiBold" Text="Developer tests"/>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                <Button Content="PineLabs" Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Command="{Binding TestPineLabsPaymentCommand}"/>
                <Button Content="Razorpay" Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Command="{Binding TestRazorpayPaymentCommand}"/>
                <Button Content="Purchase intent" Style="{StaticResource OutlineButton}" Command="{Binding TestPurchaseIntentCommand}"/>
            </StackPanel>

            <TextBlock Text="{Binding LastActionText}" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" Margin="0,8,0,16"/>

            <Button Content="Close" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Width="100" IsCancel="True" IsDefault="True" Click="Close_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>
