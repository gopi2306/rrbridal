<Window x:Class="RRBridal.StoreBilling.App.Views.HeldBillsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Held bills"
        Width="640"
        Height="420"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Select a held bill to resume or delete." Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,12"/>
        <DataGrid x:Name="BillsGrid" Grid.Row="1" Style="{StaticResource ThemedDataGrid}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  SelectionMode="Single" SelectionChanged="BillsGrid_OnSelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Hold no" Binding="{Binding HoldNo}" Width="160"/>
                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                <DataGridTextColumn Header="Payable" Binding="{Binding Payable, StringFormat=₹ {0:N2}}" Width="100"/>
                <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="80"/>
                <DataGridTextColumn Header="Held" Binding="{Binding HeldAtUtc}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="StatusText" Grid.Row="2" Margin="0,8,0,8" Foreground="{StaticResource BrushTextMuted}"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Delete hold" Style="{StaticResource OutlineButton}" Width="100" Margin="0,0,8,0" Click="Delete_Click"/>
            <Button Content="Resume" Style="{StaticResource PrimaryButton}" Width="100" Margin="0,0,8,0" Click="Resume_Click"/>
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
