<UserControl x:Class="RRBridal.StoreBilling.App.Views.Controls.BarcodeLabelPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="420" d:DesignHeight="400">
    <StackPanel Margin="0,0,16,20">
        <TextBlock x:Name="SkuHeader" FontSize="10" Foreground="#555" Margin="0,0,0,4"/>
        <TextBlock FontSize="9" Foreground="#888" Margin="0,0,0,6"
                   Text="One print row = 2 cups (same label on left and right)"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#222" BorderThickness="1" Background="White"
                    SnapsToDevicePixels="True">
                <Canvas x:Name="LabelCanvas" ClipToBounds="True"/>
            </Border>

            <Border Grid.Column="1" Margin="6,0,0,0" BorderBrush="#222" BorderThickness="1"
                    Background="White" SnapsToDevicePixels="True">
                <Canvas x:Name="RightCanvas" ClipToBounds="True"/>
            </Border>
        </Grid>

        <TextBlock x:Name="SizeCaption" FontSize="9" Foreground="#666" Margin="0,6,0,0"/>
        <TextBlock x:Name="CopyCaption" FontSize="9" FontWeight="SemiBold" Foreground="#1B5E20" Margin="0,2,0,0"/>
    </StackPanel>
</UserControl>
