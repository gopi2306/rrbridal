<UserControl x:Class="RRBridal.StoreBilling.App.Views.Controls.NavDrawerItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="44" d:DesignWidth="260">
    <Button HorizontalContentAlignment="Stretch"
            Command="{Binding NavigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
            CommandParameter="{Binding Page, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            Cursor="Hand"
            FocusVisualStyle="{x:Null}">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border x:Name="Root"
                        Background="Transparent"
                        Padding="16,12"
                        BorderThickness="3,0,0,0"
                        BorderBrush="Transparent">
                    <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontFamily="{StaticResource FontFamilyPrimary}"
                               FontSize="14"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushAccentSoft}"/>
                    </Trigger>
                    <DataTrigger Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                        <Setter TargetName="Root" Property="Background" Value="{StaticResource BrushSidebarTint}"/>
                        <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                    </DataTrigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
    </Button>
</UserControl>
