<Window x:Class="RRBridal.StoreBilling.App.Views.BarcodePrinterPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select barcode printer"
        Width="440"
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">
    <Border Style="{StaticResource CardBorder}" Margin="16" Padding="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Barcode printer (TVS LP 46 NEO)" Style="{StaticResource TextSectionTitle}" Foreground="{StaticResource BrushAccent}"/>
        <TextBlock Grid.Row="1" Margin="0,6,0,12" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}"
                   Text="Choose the Windows print queue for TVS LP 46 NEO. TSPL is sent as raw data."/>
        <ComboBox x:Name="PrinterCombo" Grid.Row="2" Style="{StaticResource RoundedComboBox}" MinHeight="32"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Width="90" Margin="0,0,8,0" IsCancel="True"/>
            <Button Content="Print" Style="{StaticResource PrimaryButton}" Width="90" IsDefault="True" Click="Print_OnClick"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
