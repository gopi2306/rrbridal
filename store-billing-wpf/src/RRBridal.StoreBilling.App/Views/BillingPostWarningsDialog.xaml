<Window x:Class="RRBridal.StoreBilling.App.Views.BillingPostWarningsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock shortage"
        Width="620"
        Height="400"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">
    <Border Style="{StaticResource CardBorder}" Margin="16" Padding="20">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,12"
                   Text="The following lines exceed local stock. Stock will not be reduced for these items. Post bill anyway?"/>
        <DataGrid x:Name="ShortGrid" Grid.Row="1" Style="{StaticResource ThemedDataGrid}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="100"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="Bill qty" Binding="{Binding Requested, StringFormat={}{0:0.###}}" Width="72"/>
                <DataGridTextColumn Header="Available" Binding="{Binding Available, StringFormat={}{0:0.###}}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Post anyway" Style="{StaticResource PrimaryButton}" Width="110" Margin="0,0,8,0" Click="PostAnyway_Click"/>
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
    </Border>
</Window>
