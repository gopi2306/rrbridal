<Window x:Class="RRBridal.StoreBilling.App.Views.BarcodeLabelPrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:RRBridal.StoreBilling.App.Views.Controls"
        Title="Barcode label preview (TVS LP 46 NEO)"
        Width="760"
        Height="620"
        MinWidth="520"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Label preview — TVS LP 46 NEO" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}"/>
        <TextBlock Grid.Row="1" Margin="0,6,0,8" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}"
                   Text="Each card is one print row on your roll: 2 cups side-by-side with the same label (76 mm row). Qty is total stickers — even qty uses full rows (e.g. 10 → 5 rows × 2). Odd qty prints one extra row with a single left cup only."/>

        <Border x:Name="ResultBanner" Grid.Row="2" Margin="0,0,0,8" Padding="10,8" CornerRadius="6"
                Background="#E8F4EA" BorderBrush="#81C784" BorderThickness="1" Visibility="Collapsed">
            <TextBlock x:Name="ResultText" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#1B5E20"/>
        </Border>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      Background="#F5F5F5" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Padding="12">
            <WrapPanel x:Name="LabelsPanel" Orientation="Horizontal"/>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="Barcode printer" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBlock Text="TSPL is sent as RAW data to your TVS LP 46 NEO queue. Each qty prints that many separate labels." FontSize="11"
                       Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,6"/>
            <ComboBox x:Name="PrinterCombo" MinHeight="32" VerticalContentAlignment="Center"
                      SelectionChanged="PrinterCombo_OnSelectionChanged"/>
            <TextBlock x:Name="PrinterWarningText" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="11"
                       Foreground="#B45309" Visibility="Collapsed"/>
        </StackPanel>

        <Grid Grid.Row="5" Margin="0,14,0,0">
            <TextBlock x:Name="SummaryText" VerticalAlignment="Center" Foreground="{StaticResource BrushTextMuted}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save label file" Style="{StaticResource OutlineButton}" Width="110" Margin="0,0,8,0"
                        ToolTip="Save TSPL/EPL commands (.tspl / .epl)" Click="SaveEpl_OnClick"/>
                <Button Content="Close" Style="{StaticResource OutlineButton}" Width="90" Margin="0,0,8,0" IsCancel="True"/>
                <Button x:Name="PrintButton" Content="Send to printer" Style="{StaticResource PrimaryButton}" Width="140"
                        Click="Print_OnClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
