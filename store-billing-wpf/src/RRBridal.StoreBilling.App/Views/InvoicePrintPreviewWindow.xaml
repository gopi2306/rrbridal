<Window x:Class="RRBridal.StoreBilling.App.Views.InvoicePrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Invoice preview"
        Width="420"
        Height="560"
        MinWidth="360"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" Background="White" Padding="4">
            <FlowDocumentScrollViewer x:Name="PreviewViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
        </Border>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="PrintButton" Content="Print" Style="{StaticResource PrimaryButton}" MinWidth="100" Margin="0,0,10,0" Click="Print_OnClick"/>
            <Button Content="Close" Style="{StaticResource OutlineButton}" MinWidth="80" IsCancel="True" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
