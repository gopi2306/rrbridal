<UserControl x:Class="RRBridal.StoreBilling.App.Views.DailyExpenseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Daily Expenses" Style="{StaticResource TextPageTitleAccent}"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="{Binding StoreDisplayName, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource BrushText}"/>
                <TextBlock Text="{Binding TillDisplayLine, Mode=OneWay}" Style="{StaticResource PageSubtitle}" Margin="8,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource FilterBarCard}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Style="{StaticResource TextSectionTitle}" Text="New expense slip" Margin="0,0,0,12"/>
                    <UniformGrid
                                 ui:UniformGridColumnsBehavior.IsEnabled="True"
                                 ui:UniformGridColumnsBehavior.CompactColumns="1"
                                 ui:UniformGridColumnsBehavior.MediumColumns="2"
                                 ui:UniformGridColumnsBehavior.WideColumns="2">
                        <StackPanel Margin="0,0,12,8">
                            <TextBlock Text="Date" Style="{StaticResource FormFieldLabel}"/>
                            <DatePicker SelectedDate="{Binding SelectedDate}" Style="{StaticResource RoundedDatePicker}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="Amount (₹)" Style="{StaticResource FormFieldLabel}"/>
                            <TextBox Style="{StaticResource RoundedTextBox}"
                                     Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </UniformGrid>
                    <StackPanel Margin="0,4,0,0">
                        <TextBlock Text="Description" Style="{StaticResource FormFieldLabel}"/>
                        <TextBox Style="{StaticResource RoundedTextBox}"
                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>
                <WrapPanel Grid.Column="1" VerticalAlignment="Bottom">
                    <Button Content="Refresh" Style="{StaticResource OutlineButton}" MinWidth="90" Margin="0,0,8,4"
                            Command="{Binding RefreshCommand}"/>
                    <Button Content="Post expense" Style="{StaticResource PrimaryButton}" MinWidth="130" Margin="0,0,0,4"
                            Command="{Binding PostExpenseCommand}"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource TextSectionTitle}" Text="Expenses for selected date"/>
                    <Border Style="{StaticResource StatusChip}" Margin="12,0,0,0">
                        <TextBlock Text="{Binding DayTotalSummary, StringFormat=Total: {0}}"
                                   FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}" FontSize="12"/>
                    </Border>
                </StackPanel>
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}"
                           Margin="0,10,0,0" TextWrapping="Wrap"/>
                <DataGrid ItemsSource="{Binding Expenses}"
                          Style="{StaticResource ThemedDataGrid}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Expense no" Binding="{Binding ExpenseNo}" Width="180"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="110"/>
                        <DataGridTextColumn Header="Posted" Binding="{Binding PostedAtLocal}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
