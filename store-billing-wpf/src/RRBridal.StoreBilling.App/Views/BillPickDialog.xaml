<Window x:Class="RRBridal.StoreBilling.App.Views.BillPickDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select bill"
        Width="560"
        Height="420"
        MinHeight="320"
        MinWidth="480"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Multiple bills match. Select the original bill for this return."
                   Style="{StaticResource TextSectionTitle}" TextWrapping="Wrap"/>

        <ListView Grid.Row="1" Margin="0,12,0,12"
                  x:Name="ResultsList"
                  ItemsSource="{Binding Bills}"
                  SelectedItem="{Binding SelectedBill}"
                  MouseDoubleClick="Results_OnMouseDoubleClick"
                  BorderBrush="{StaticResource BrushBorder}"
                  Background="{StaticResource BrushSurface}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Bill No" DisplayMemberBinding="{Binding BillNo}" Width="140"/>
                    <GridViewColumn Header="Date" DisplayMemberBinding="{Binding BillDate}" Width="110"/>
                    <GridViewColumn Header="Customer" DisplayMemberBinding="{Binding CustomerName}" Width="160"/>
                    <GridViewColumn Header="Payable" DisplayMemberBinding="{Binding PayableDisplay}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Width="90" Margin="0,0,8,0"
                    IsCancel="True" Click="Cancel_OnClick"/>
            <Button Content="Select" Style="{StaticResource PrimaryButton}" Width="100" IsDefault="True"
                    Click="Select_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
