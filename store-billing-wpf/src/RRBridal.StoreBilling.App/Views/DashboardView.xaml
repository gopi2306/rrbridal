<UserControl x:Class="RRBridal.StoreBilling.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="{StaticResource BrushBackground}">
    <!-- Grid + * row: TabControl inside ScrollViewer often measures to zero height (see LedgerView). -->
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="320"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Dashboard" Style="{StaticResource TextPageTitle}" Foreground="{StaticResource BrushAccent}"/>
                <StackPanel Margin="0,4,0,0">
                    <TextBlock Text="{Binding StoreDisplayName, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource BrushText}"/>
                    <TextBlock Text="{Binding TillDisplayLine, Mode=OneWay}" FontSize="12" Foreground="{StaticResource BrushTextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Counter filter:" VerticalAlignment="Center" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,8,0"/>
                    <ComboBox Style="{StaticResource RoundedComboBox}" ItemsSource="{Binding PosCounterFilterOptions}"
                              SelectedItem="{Binding SelectedPosCounterFilter}"
                              DisplayMemberPath="Label"
                              MinWidth="160"/>
                </StackPanel>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Content="Refresh metrics" Style="{StaticResource PrimaryButton}"
                    Command="{Binding RefreshCommand}" Width="140"/>
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <TabControl Grid.Row="2" Style="{StaticResource ThemedTabControl}" VerticalAlignment="Stretch">
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,8,0,16">
                        <TextBlock Text="{Binding StoreWideTodaySummary}" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                        <TextBlock Text="Today &amp; week (local posted bills)" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource BrushText}"/>
                        <UniformGrid Margin="0,0,0,8"
                                     ui:UniformGridColumnsBehavior.IsEnabled="True"
                                     ui:UniformGridColumnsBehavior.CompactColumns="1"
                                     ui:UniformGridColumnsBehavior.MediumColumns="2"
                                     ui:UniformGridColumnsBehavior.WideColumns="2">
                            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,8" BorderBrush="{StaticResource BrushAccent}">
                                <StackPanel>
                                    <TextBlock Text="Today" Style="{StaticResource TextCaption}"/>
                                    <TextBlock Text="{Binding BillsTodaySummary}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="8,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Last 7 days" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                    <TextBlock Text="{Binding BillsWeekSummary}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <UniformGrid Margin="0,0,0,16"
                                     ui:UniformGridColumnsBehavior.IsEnabled="True"
                                     ui:UniformGridColumnsBehavior.CompactColumns="1"
                                     ui:UniformGridColumnsBehavior.MediumColumns="2"
                                     ui:UniformGridColumnsBehavior.WideColumns="3">
                            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" BorderBrush="{StaticResource BrushAccent}">
                                <StackPanel>
                                    <TextBlock Text="COD balance till" Style="{StaticResource TextCaption}"/>
                                    <TextBlock Text="{Binding CodBalanceTillSummary}" FontSize="18" FontWeight="SemiBold"/>
                                    <Button Content="Online sales" Style="{StaticResource OutlineButton}" Margin="0,8,0,0" Padding="8,4"
                                            Command="{Binding OpenOnlineSalesPageCommand}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="Pending outbox" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                    <TextBlock Text="{Binding PendingOutboxSummary}" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="Sync" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                    <TextBlock Text="{Binding SyncSummary}" FontSize="13" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Products in local cache" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                    <TextBlock Text="{Binding ProductCacheSummary}" FontSize="18" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="Recent bills" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource BrushText}"/>
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16" Padding="8">
                            <DataGrid ItemsSource="{Binding RecentBills}"
                                      Style="{StaticResource ThemedDataGrid}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      MaxHeight="220">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="120"/>
                                    <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="130"/>
                                    <DataGridTextColumn Header="Posted (UTC)" Binding="{Binding CreatedAtDisplay}" Width="*"/>
                                    <DataGridTextColumn Header="Payable" Binding="{Binding Payable, StringFormat=₹ {0:N2}}" Width="110"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <TextBlock Text="Store inventory lookup (local)" FontWeight="SemiBold" Margin="0,0,0,4" Foreground="{StaticResource BrushText}"/>
                        <TextBlock Text="Filter by local store quantity. Billing search still shows in-stock items only."
                                   FontSize="12" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InventorySearchBox" Grid.Column="0" Style="{StaticResource RoundedTextBox}" Margin="0,0,8,0"
                                     Text="{Binding InventorySearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="SKU, barcode, or name — Enter to search"
                                     KeyDown="InventorySearchBox_OnKeyDown"/>
                            <ComboBox Grid.Column="1" Style="{StaticResource RoundedComboBox}" Width="170" Margin="0,0,8,0"
                                      ItemsSource="{Binding StockFilterOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding InventoryStockFilter}"
                                      ToolTip="Stock filter"/>
                            <Button Grid.Column="2" Content="Search inventory" Style="{StaticResource PrimaryButton}" Width="140"
                                    Command="{Binding SearchInventoryCommand}"/>
                        </Grid>

                        <TextBlock Text="{Binding InventoryHint}" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,4"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                            <Button Content="← Previous" Style="{StaticResource OutlineButton}" Padding="12,6" Margin="0,0,8,0"
                                    Command="{Binding InventoryPreviousPageCommand}"/>
                            <TextBlock Text="{Binding InventoryPagerLabel}" VerticalAlignment="Center" Margin="0,0,8,0"
                                       MinWidth="160" TextAlignment="Center" Foreground="{StaticResource BrushText}"/>
                            <Button Content="Next →" Style="{StaticResource OutlineButton}" Padding="12,6"
                                    Command="{Binding InventoryNextPageCommand}"/>
                        </StackPanel>

                        <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0">
                            <DataGrid ItemsSource="{Binding InventoryRows}"
                                      Style="{StaticResource ThemedDataGrid}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      MinHeight="200"
                                      MaxHeight="320">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="100"/>
                                    <DataGridTextColumn Header="UPC/EAN" Binding="{Binding UpcEanCode}" Width="100"/>
                                    <DataGridTextColumn Header="Product" Binding="{Binding Product}" Width="*"/>
                                    <DataGridTextColumn Header="Local store qty" Binding="{Binding StoreQty, StringFormat={}{0:N2}}" Width="120"/>
                                    <DataGridTextColumn Header="MRP" Binding="{Binding Mrp, StringFormat=₹ {0:N2}}" Width="85"/>
                                    <DataGridTextColumn Header="Store price" Binding="{Binding StorePrice, StringFormat=₹ {0:N2}}" Width="95"/>
                                    <DataGridTemplateColumn Header="" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Adjust"
                                                        Style="{StaticResource OutlineButton}"
                                                        Padding="8,2"
                                                        Command="{Binding DataContext.AdjustInventoryStockCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Day close">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,8,0,16">

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Business date:" VerticalAlignment="Center" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,8,0"/>
                        <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding SelectedCloseDate}" Width="140" Margin="0,0,16,0"/>
                        <Button Content="Refresh day close" Style="{StaticResource PrimaryButton}" Width="140" Margin="0,0,8,0"
                                Command="{Binding LoadDayCloseCommand}"/>
                        <Button Content="Download full report" Style="{StaticResource OutlineButton}" Width="160"
                                Command="{Binding DownloadDayCloseReportCommand}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding DayCloseStatusMessage}" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                    <UniformGrid Margin="0,0,0,8"
                                 ui:UniformGridColumnsBehavior.IsEnabled="True"
                                 ui:UniformGridColumnsBehavior.CompactColumns="1"
                                 ui:UniformGridColumnsBehavior.MediumColumns="2"
                                 ui:UniformGridColumnsBehavior.WideColumns="3">
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Total bills" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseBillCountSummary}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="4,0,4,8">
                            <StackPanel>
                                <TextBlock Text="Total qty sold" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseQtySummary}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="8,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Total amount" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseAmountSummary}" FontSize="18" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Margin="0,0,0,12"
                                 ui:UniformGridColumnsBehavior.IsEnabled="True"
                                 ui:UniformGridColumnsBehavior.CompactColumns="1"
                                 ui:UniformGridColumnsBehavior.MediumColumns="2"
                                 ui:UniformGridColumnsBehavior.WideColumns="4">
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Cash" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseCashSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="Card" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseCardSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="UPI" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseUpiSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="CN used (billing)" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseCreditNoteSummary}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Margin="0,0,0,8"
                                 ui:UniformGridColumnsBehavior.IsEnabled="True"
                                 ui:UniformGridColumnsBehavior.CompactColumns="1"
                                 ui:UniformGridColumnsBehavior.MediumColumns="2"
                                 ui:UniformGridColumnsBehavior.WideColumns="4">
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Return count" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseReturnCountSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="Total return amount" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseReturnTotalSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="Cash refunded" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseCashRefundSummary}" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DayCloseCashRefundDetailSummary}" FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                                           TextWrapping="Wrap" Margin="0,2,0,0"
                                           Visibility="{Binding DayCloseShowCashRefundDetail, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="CN issued" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseCnIssuedSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Margin="0,0,0,8"
                                 ui:UniformGridColumnsBehavior.IsEnabled="True"
                                 ui:UniformGridColumnsBehavior.CompactColumns="1"
                                 ui:UniformGridColumnsBehavior.MediumColumns="2"
                                 ui:UniformGridColumnsBehavior.WideColumns="4">
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Online COD pending (not in cash)" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseOnlineCodPendingSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="Daily expenses (deducted from net cash)" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseDailyExpensesSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Margin="0,0,0,12"
                                 ui:UniformGridColumnsBehavior.IsEnabled="True"
                                 ui:UniformGridColumnsBehavior.CompactColumns="1"
                                 ui:UniformGridColumnsBehavior.MediumColumns="2"
                                 ui:UniformGridColumnsBehavior.WideColumns="4">
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Net cash" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseNetCashSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="Net card" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseNetCardSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="Net UPI" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseNetUpiSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Expected tender total" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseActualHandInSummary}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Margin="0,0,0,12"
                                 ui:UniformGridColumnsBehavior.IsEnabled="True"
                                 ui:UniformGridColumnsBehavior.CompactColumns="1"
                                 ui:UniformGridColumnsBehavior.MediumColumns="2"
                                 ui:UniformGridColumnsBehavior.WideColumns="3">
                        <Border Style="{StaticResource CardBorder}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="Expected cash (drawer)" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseExpectedCashSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="4,0">
                            <StackPanel>
                                <TextBlock Text="Deposits to bank" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseDepositsSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Cash withdrawals" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding DayCloseWithdrawalsSummary}" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <TextBlock Text="Store day-close rollup (all counters)" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding StoreRollupRows}" Style="{StaticResource ThemedDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MaxHeight="180" Margin="0,0,0,12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Counter" Binding="{Binding PosCounter}" Width="80"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="70"/>
                            <DataGridTextColumn Header="Opening" Binding="{Binding OpeningCashDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Expected" Binding="{Binding ExpectedCashDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Actual" Binding="{Binding ActualCashDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Diff" Binding="{Binding DifferenceDisplay}" Width="90"/>
                            <DataGridTextColumn Header="Closed by" Binding="{Binding ClosedBy}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Text="Returns for selected day" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource BrushText}"/>
                    <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,12">
                        <DataGrid ItemsSource="{Binding DayReturns}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  MaxHeight="240"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Return no" Binding="{Binding ReturnNo}" Width="110"/>
                                <DataGridTextColumn Header="Original bill" Binding="{Binding OriginalBillNo}" Width="110"/>
                                <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="90"/>
                                <DataGridTextColumn Header="Posted (local)" Binding="{Binding PostedAtLocal}" Width="130"/>
                                <DataGridTextColumn Header="Return total" Binding="{Binding ReturnTotal, StringFormat=₹ {0:N2}}" Width="100"/>
                                <DataGridTextColumn Header="Mode" Binding="{Binding ReturnMode}" Width="80"/>
                                <DataGridTextColumn Header="Cash refunded" Binding="{Binding CashRefunded, StringFormat=₹ {0:N2}}" Width="100"/>
                                <DataGridTextColumn Header="Credit balance" Binding="{Binding CreditBalance, StringFormat=₹ {0:N2}}" Width="100"/>
                                <DataGridTextColumn Header="Collected" Binding="{Binding AmountCollected, StringFormat=₹ {0:N2}}" Width="90"/>
                                <DataGridTextColumn Header="Payments" Binding="{Binding PaymentSummary}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <TextBlock Text="Invoices for selected day" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource BrushText}"/>
                    <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,12">
                        <DataGrid ItemsSource="{Binding DayInvoices}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  MaxHeight="280"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="120"/>
                                <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="100"/>
                                <DataGridTextColumn Header="Posted (local)" Binding="{Binding PostedAtLocal}" Width="140"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding TotalQty, StringFormat={}{0:N2}}" Width="70"/>
                                <DataGridTextColumn Header="Payable" Binding="{Binding Payable, StringFormat=₹ {0:N2}}" Width="100"/>
                                <DataGridTextColumn Header="Payment" Binding="{Binding PaymentMode}" Width="80"/>
                                <DataGridTextColumn Header="Sync" Binding="{Binding SyncStatus}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <TextBlock Text="Stock exceptions (selected day)" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="{StaticResource BrushText}"/>
                    <Border Style="{StaticResource CardBorder}" Padding="8">
                        <DataGrid ItemsSource="{Binding StockExceptions}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  MaxHeight="240"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="110"/>
                                <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="90"/>
                                <DataGridTextColumn Header="Posted" Binding="{Binding PostedAtLocal}" Width="130"/>
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="90"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="Requested" Binding="{Binding RequestedQty, StringFormat={}{0:N2}}" Width="80"/>
                                <DataGridTextColumn Header="Available" Binding="{Binding AvailableQty, StringFormat={}{0:N2}}" Width="80"/>
                                <DataGridTemplateColumn Header="Action" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Approve"
                                                    Style="{StaticResource PrimaryButton}"
                                                    Padding="8,4"
                                                    Command="{Binding DataContext.ApproveStockExceptionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding BillNo}"
                                                    IsEnabled="{Binding CanApprove}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Salesman">
                <Grid Margin="0,8,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Salesman filter" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <ComboBox Style="{StaticResource RoundedComboBox}"
                                          ItemsSource="{Binding SalesmanFilterOptions}"
                                          SelectedItem="{Binding SelectedSalesmanFilter}"
                                          DisplayMemberPath="Label"
                                          MinWidth="200"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,8,0"
                                        Visibility="{Binding FilterUseDateRange, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <TextBlock Text="Business date" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding FilterBusinessDate}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <CheckBox Content="Date range" IsChecked="{Binding FilterUseDateRange}" Margin="0,0,0,8"/>
                                <Button Content="Refresh" Style="{StaticResource PrimaryButton}" MinWidth="100"
                                        Command="{Binding LoadSalesmanSummaryCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="1" Text="{Binding SalesmanTabStatusMessage}" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>

                    <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,12" MaxHeight="220">
                        <DataGrid ItemsSource="{Binding SalesmanSummaryRows}"
                                  SelectedItem="{Binding SelectedSalesmanSummary}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding SalesmanCode}" Width="75"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding SalesmanName}" Width="*"/>
                                <DataGridTextColumn Header="Bills" Binding="{Binding BillCount}" Width="55"/>
                                <DataGridTextColumn Header="Qty sold" Binding="{Binding TotalQtyFormatted}" Width="80"/>
                                <DataGridTextColumn Header="Bill amount" Binding="{Binding TotalPayableFormatted}" Width="105"/>
                                <DataGridTextColumn Header="Avg bill" Binding="{Binding AvgPayableFormatted}" Width="95"/>
                                <DataGridTextColumn Header="Cash" Binding="{Binding TotalCashFormatted}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <TextBlock Grid.Row="3" Text="{Binding SalesmanBillTotalsSummary}" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="8">
                        <DataGrid ItemsSource="{Binding SalesmanBillRows}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="115"/>
                                <DataGridTextColumn Header="Bill date" Binding="{Binding BillDate}" Width="95"/>
                                <DataGridTextColumn Header="Posted" Binding="{Binding PostedAtLocal}" Width="125"/>
                                <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="90"/>
                                <DataGridTextColumn Header="Salesman" Binding="{Binding SalesmanDisplay}" Width="120"/>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="120"/>
                                <DataGridTextColumn Header="Mobile" Binding="{Binding CustomerPhone}" Width="100"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding TotalQty, StringFormat={}{0:N2}}" Width="55"/>
                                <DataGridTextColumn Header="Payable" Binding="{Binding PayableFormatted}" Width="90"/>
                                <DataGridTextColumn Header="Cash" Binding="{Binding CashFormatted}" Width="80"/>
                                <DataGridTextColumn Header="Card" Binding="{Binding CardFormatted}" Width="80"/>
                                <DataGridTextColumn Header="UPI" Binding="{Binding UpiFormatted}" Width="80"/>
                                <DataGridTextColumn Header="Sync" Binding="{Binding SyncStatus}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Stock sales">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,8,0,16">

                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                <TextBlock Text="View" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <ComboBox Style="{StaticResource RoundedComboBox}"
                                          ItemsSource="{Binding StockSalesViewModeOptions}"
                                          SelectedItem="{Binding SelectedStockSalesViewModeOption}"
                                          DisplayMemberPath="Label"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,4,8">
                                <TextBlock Text="Brand" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <ComboBox Style="{StaticResource RoundedComboBox}"
                                          ItemsSource="{Binding StockSalesBrandFilterOptions}"
                                          SelectedItem="{Binding SelectedStockBrandFilter}"
                                          DisplayMemberPath="Label"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="4,0,4,8">
                                <TextBlock Text="Stock filter" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <ComboBox Style="{StaticResource RoundedComboBox}"
                                          ItemsSource="{Binding StockAvailabilityFilterOptions}"
                                          SelectedItem="{Binding SelectedStockAvailabilityFilter}"
                                          DisplayMemberPath="Label"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="3" Margin="4,0,4,8">
                                <TextBlock Text="Brand name search" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}"
                                         Text="{Binding FilterStockBrandName, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Filter by brand name (e.g. PAKEEZA)"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="4" Margin="4,0,0,8">
                                <TextBlock Text="Product code / name" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBox Style="{StaticResource RoundedTextBox}"
                                         Text="{Binding FilterStockProductSearch, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="5" VerticalAlignment="Bottom" Margin="8,0,0,8">
                                <Button Content="Refresh" Style="{StaticResource PrimaryButton}" MinWidth="100"
                                        Command="{Binding LoadStockSalesCommand}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                        Visibility="{Binding FilterUseDateRange, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <TextBlock Text="Business date" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding FilterBusinessDate}"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="4,0,0,0">
                                <CheckBox Content="Use date range" IsChecked="{Binding FilterUseDateRange}" Margin="0,18,0,4"/>
                                <StackPanel Orientation="Horizontal"
                                            Visibility="{Binding FilterUseDateRange, Converter={StaticResource BoolToVis}}">
                                    <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding FilterDateFrom}" Width="130" Margin="0,0,8,0"/>
                                    <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding FilterDateTo}" Width="130"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="{Binding StockSalesTotalsSummary}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding StockSalesStatusMessage}" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>

                    <Border Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,12"
                            Visibility="{Binding IsStockSalesBrandView, Converter={StaticResource BoolToVis}}">
                        <DataGrid ItemsSource="{Binding StockSalesBrandRows}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  MinHeight="280"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Brand code" Binding="{Binding BrandCode}" Width="90"/>
                                <DataGridTextColumn Header="Brand" Binding="{Binding BrandName}" Width="*"/>
                                <DataGridTextColumn Header="Products" Binding="{Binding ProductCount}" Width="75"/>
                                <DataGridTextColumn Header="Bills" Binding="{Binding BillCount}" Width="60"/>
                                <DataGridTextColumn Header="Qty sold" Binding="{Binding TotalQtyFormatted}" Width="85"/>
                                <DataGridTextColumn Header="Available qty" Binding="{Binding AvailableQtyFormatted}" Width="95"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmountFormatted}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Padding="8"
                            Visibility="{Binding IsStockSalesProductView, Converter={StaticResource BoolToVis}}">
                        <DataGrid ItemsSource="{Binding StockSalesProductRows}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  MinHeight="280"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="110"/>
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Brand" Binding="{Binding BrandName}" Width="130"/>
                                <DataGridTextColumn Header="Bills" Binding="{Binding BillCount}" Width="60"/>
                                <DataGridTextColumn Header="Qty sold" Binding="{Binding TotalQtyFormatted}" Width="85"/>
                                <DataGridTextColumn Header="Available qty" Binding="{Binding AvailableQtyFormatted}" Width="95"/>
                                <DataGridTextColumn Header="Age" Binding="{Binding AgeDisplay}" Width="75"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding TotalAmountFormatted}" Width="110"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="All bills">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,8,0,16">

                    <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Search posted bills" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="Invoice no" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding FilterInvoiceNo, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,4,8">
                                    <TextBlock Text="Customer name" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding FilterCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,8">
                                    <TextBlock Text="Customer mobile" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding FilterCustomerMobile, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"
                                            Visibility="{Binding FilterUseDateRange, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                    <TextBlock Text="Business date" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                    <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding FilterBusinessDate}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="4,0,4,0">
                                    <TextBlock Text="Salesman" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                    <ComboBox Style="{StaticResource RoundedComboBox}"
                                              ItemsSource="{Binding SalesmanFilterOptions}"
                                              SelectedItem="{Binding SelectedSalesmanFilter}"
                                              DisplayMemberPath="Label"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="8,0,0,0">
                                    <CheckBox Content="Use date range" IsChecked="{Binding FilterUseDateRange}" Margin="0,18,0,4"/>
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,0"
                                            Visibility="{Binding FilterUseDateRange, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="From / To" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding FilterDateFrom}" Width="130" Margin="0,0,8,0"/>
                                        <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding FilterDateTo}" Width="130"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button Content="Download report" Style="{StaticResource OutlineButton}" Margin="0,0,8,0"
                                        Command="{Binding DownloadBillListReportCommand}"/>
                                <Button Content="Search" Style="{StaticResource PrimaryButton}" Width="100"
                                        Command="{Binding LoadBillListCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding BillListTotalsSummary}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding BillListStatusMessage}" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>

                    <Border Style="{StaticResource CardBorder}" Padding="8">
                        <DataGrid ItemsSource="{Binding BillListRows}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  MinHeight="280"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="120"/>
                                <DataGridTextColumn Header="Posted" Binding="{Binding PostedAtLocal}" Width="130"/>
                                <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="90"/>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="120"/>
                                <DataGridTextColumn Header="Salesman" Binding="{Binding SalesmanDisplay}" Width="130"/>
                                <DataGridTextColumn Header="Mobile" Binding="{Binding CustomerPhone}" Width="100"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding TotalQty, StringFormat={}{0:N2}}" Width="55"/>
                                <DataGridTextColumn Header="Payable" Binding="{Binding PayableFormatted}" Width="95"/>
                                <DataGridTextColumn Header="Cash" Binding="{Binding CashFormatted}" Width="85"/>
                                <DataGridTextColumn Header="Card" Binding="{Binding CardFormatted}" Width="85"/>
                                <DataGridTextColumn Header="UPI" Binding="{Binding UpiFormatted}" Width="85"/>
                                <DataGridTextColumn Header="Credit note" Binding="{Binding CreditNoteFormatted}" Width="95"/>
                                <DataGridTextColumn Header="Returned" Binding="{Binding ReturnedDisplay}" Width="70"/>
                                <DataGridTextColumn Header="Adjustment" Binding="{Binding AdjustmentDisplay}" Width="80"/>
                                <DataGridTextColumn Header="Sync" Binding="{Binding SyncStatus}" Width="90"/>
                                <DataGridTemplateColumn Header="Actions" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="View"
                                                        ToolTip="View bill details"
                                                        Style="{StaticResource OutlineButton}"
                                                        Padding="6,2"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.ViewBillDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Open"
                                                        ToolTip="Open return or adjustment"
                                                        Style="{StaticResource OutlineButton}"
                                                        Padding="6,2"
                                                        Command="{Binding DataContext.RedirectBillRelatedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding CanRedirect, Converter={StaticResource BoolToVis}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
