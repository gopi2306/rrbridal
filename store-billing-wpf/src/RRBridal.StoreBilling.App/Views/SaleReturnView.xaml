<UserControl x:Class="RRBridal.StoreBilling.App.Views.SaleReturnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BrushBackground}">
    <Grid x:Name="MasterDetailGrid" Background="{StaticResource BrushBackground}"
          ui:MasterDetailLayoutBehavior.IsEnabled="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource TextSectionTitle}" Text="Sale Return" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Original bill no" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                                <TextBox Style="{StaticResource RoundedTextBox}"
                                         Margin="0,4,0,0"
                                         Text="{Binding OriginalBillNo, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Full bill no or partial match"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Customer name" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                                <TextBox Style="{StaticResource RoundedTextBox}"
                                         Margin="0,4,0,0"
                                         Text="{Binding SearchCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Customer mobile" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                                <TextBox Style="{StaticResource RoundedTextBox}"
                                         Margin="0,4,0,0"
                                         Text="{Binding SearchCustomerPhone, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <Button Grid.Column="3" Content="Search" Style="{StaticResource PrimaryButton}"
                                    VerticalAlignment="Bottom" Width="100" Padding="14,8"
                                    Command="{Binding SearchBillsCommand}"/>
                        </Grid>
                        <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                                   Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Padding="8"
                        Visibility="{Binding ShowSearchResults, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" MinHeight="200"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid Grid.Row="0"
                                  ItemsSource="{Binding SearchResults}"
                                  SelectedItem="{Binding SelectedSearchBill}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  MaxHeight="320"
                                  MouseDoubleClick="SearchResults_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="120"/>
                                <DataGridTextColumn Header="Date" Binding="{Binding BillDate}" Width="100"/>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Mobile" Binding="{Binding CustomerPhone}" Width="110"/>
                                <DataGridTextColumn Header="Payable" Binding="{Binding Payable, StringFormat=₹ {0:N2}}" Width="100"/>
                                <DataGridTextColumn Header="Counter" Binding="{Binding CounterDisplay}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Grid.Row="1" Content="Load bill" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Right" Margin="0,12,0,0" Width="120"
                                Command="{Binding OpenSelectedBillCommand}"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0"
                        Visibility="{Binding BillLoaded, Converter={StaticResource BoolToVis}}">
                    <DockPanel LastChildFill="True">
                        <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" FontSize="15" Text="Return Items" Margin="0,0,0,10"/>
                        <DataGrid ItemsSource="{Binding ReturnLines}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  RowHeight="36"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BrushBorder}">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Select" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="55">
                                    <DataGridCheckBoxColumn.ElementStyle>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="IsEnabled" Value="{Binding CanSelect}"/>
                                        </Style>
                                    </DataGridCheckBoxColumn.ElementStyle>
                                </DataGridCheckBoxColumn>
                                <DataGridTextColumn Header="S.No" Binding="{Binding LineNo}" IsReadOnly="True" Width="50"/>
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductCode}" IsReadOnly="True" Width="110"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True" Width="*"/>
                                <DataGridTextColumn Header="Orig Qty" Binding="{Binding OriginalQty}" IsReadOnly="True" Width="70"/>
                                <DataGridTextColumn Header="Prev Ret" Binding="{Binding PreviouslyReturnedQty}" IsReadOnly="True" Width="70">
                                    <DataGridTextColumn.Visibility>
                                        <Binding Path="ShowPriorReturnQty" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                    </DataGridTextColumn.Visibility>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Return Qty" Binding="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                <DataGridTextColumn Header="Rate" Binding="{Binding Rate}" IsReadOnly="True" Width="80"/>
                                <DataGridTextColumn Header="Disc (₹)" Binding="{Binding ReturnDiscountAmount, StringFormat=N2}" IsReadOnly="True" Width="80"/>
                                <DataGridTextColumn Header="Taxable amt" Binding="{Binding TaxableReturnAmount, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                                <DataGridTextColumn Header="Tax %" Binding="{Binding TaxPercent}" IsReadOnly="True" Width="60"/>
                                <DataGridTextColumn Header="Tax Amt" Binding="{Binding TaxAmount, StringFormat=N2}" IsReadOnly="True" Width="80"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding LineReturnTotal, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,12,0,0"
                        Visibility="{Binding BillLoaded, Converter={StaticResource BoolToVis}}">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock FontWeight="SemiBold" FontSize="15" Text="New Exchange Items"/>
                            <TextBlock Text="Use the top search box to add replacement products from local inventory."
                                       Foreground="{StaticResource BrushTextMuted}" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding ExchangeLines}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  RowHeight="36"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BrushBorder}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductCode}" IsReadOnly="True" Width="110"/>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" IsReadOnly="True" Width="*"/>
                                <DataGridTextColumn Header="Avail" Binding="{Binding AvailableQty, StringFormat=N2}" IsReadOnly="True" Width="70"/>
                                <DataGridTextColumn Header="New Qty" Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                <DataGridTextColumn Header="Rate" Binding="{Binding Rate, StringFormat=N2}" IsReadOnly="True" Width="80"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                                <DataGridTextColumn Header="Tax Amt" Binding="{Binding TaxAmount, StringFormat=N2}" IsReadOnly="True" Width="80"/>
                                <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=N2}" IsReadOnly="True" Width="90"/>
                                <DataGridTemplateColumn Header="" Width="48">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource IconDeleteButton}"
                                                    HorizontalAlignment="Center"
                                                    Command="{Binding DataContext.RemoveExchangeLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Background="{StaticResource BrushSidebarTint}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="10" Padding="0"
                Visibility="{Binding BillLoaded, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BrushAccent}" CornerRadius="10,10,0,0" Padding="14,12">
                    <StackPanel>
                        <TextBlock Text="RETURN SUMMARY" Foreground="White" FontWeight="Bold" FontSize="12" Opacity="0.95"/>
                        <TextBlock Text="{Binding ReturnNo, StringFormat=RETURN NO: {0}}" Foreground="White" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="14,12" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Gross sub total" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding GrossSubTotalFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Return discount" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding ReturnDiscountFormatted}" HorizontalAlignment="Right" Foreground="{StaticResource BrushNegative}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Taxable sub total" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding TaxableSubTotalFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="CGST" Foreground="{StaticResource BrushTextMuted}"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                            <TextBlock Text="{Binding CgstTotalFormatted}" HorizontalAlignment="Right"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="SGST" Foreground="{StaticResource BrushTextMuted}"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                            <TextBlock Text="{Binding SgstTotalFormatted}" HorizontalAlignment="Right"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="IGST" Foreground="{StaticResource BrushTextMuted}"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding IgstTotalFormatted}" HorizontalAlignment="Right"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Tax total" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding TaxTotalFormatted}" HorizontalAlignment="Right"/>
                        </Grid>

                        <Separator Margin="0,8,0,12"/>

                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Old return value" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding ReturnTotalFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="New product value" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding ReplacementTotalFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Amount to collect" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding AmountToCollectFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Credit balance" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding CreditBalanceFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>

                        <Separator Margin="0,8,0,12"/>

                        <TextBlock Text="Return Mode" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <RadioButton Content="Credit Note" GroupName="ReturnMode"
                                     IsChecked="{Binding ReturnMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=CreditNote}"
                                     Margin="0,0,0,4"/>
                        <RadioButton Content="Cash Refund" GroupName="ReturnMode"
                                     IsChecked="{Binding ReturnMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=CashRefund}"
                                     Margin="0,0,0,8"/>

                        <Separator Margin="0,4,0,12"/>

                        <TextBlock Text="Reason" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Content="Clear" Style="{StaticResource OutlineButton}" Command="{Binding ClearFormCommand}" Margin="0,0,8,0"/>
                            <Button Content="Post Return / Exchange" Style="{StaticResource PrimaryButton}" Command="{Binding PostReturnCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="{StaticResource BrushAccent}" CornerRadius="0,0,10,10" Padding="14,14">
                    <Grid>
                        <TextBlock Text="{Binding FooterLabel}" Foreground="White" Opacity="0.9" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding FooterAmountFormatted}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
