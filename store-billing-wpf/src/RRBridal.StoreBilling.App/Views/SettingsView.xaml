<UserControl x:Class="RRBridal.StoreBilling.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="720"
             Loaded="SettingsView_OnLoaded"
             FontFamily="{StaticResource FontFamilyPrimary}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource BrushBackground}">
    <UserControl.Resources>
        <Style x:Key="SettingsFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource TextLabel}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,10"/>
        </Style>
        <Style x:Key="SettingsFieldInput" TargetType="TextBox" BasedOn="{StaticResource RoundedTextBox}">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="SettingsNumericInput" TargetType="TextBox" BasedOn="{StaticResource RoundedTextBox}">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SettingsStatusBox" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushRowAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </UserControl.Resources>

    <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Settings &amp; sync" Style="{StaticResource TextPageTitle}" Foreground="{StaticResource BrushAccent}"/>
            <TextBlock Text="Central connection, sync, receipt printing, and developer tools."
                       Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" Style="{StaticResource ThemedTabControl}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <TabItem Header="Connection &amp; sync">
                <Grid Margin="0,8,0,0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0" VerticalAlignment="Stretch">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Central connection" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Authenticate this counter with the central backend."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Email" Style="{StaticResource SettingsFieldLabel}"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                                 Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Password" Style="{StaticResource SettingsFieldLabel}"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                                 Text="{Binding LoginPassword, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,14">
                                        <Button Content="Login" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                                Command="{Binding LoginCentralCommand}" MinWidth="100"/>
                                        <Button Content="Logout" Style="{StaticResource OutlineButton}"
                                                Command="{Binding LogoutCentralCommand}" MinWidth="100"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Style="{StaticResource SettingsStatusBox}" Margin="0" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding AuthStatusText}" Style="{StaticResource TextBody}" FontWeight="SemiBold"/>
                                </Border>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="0" VerticalAlignment="Stretch">
                            <DockPanel LastChildFill="True">
                                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Sync" Style="{StaticResource TextSectionTitle}"/>
                                        <TextBlock Text="Push local bills and pull master data from central."
                                                   Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                        <Button Content="Refresh" Style="{StaticResource OutlineButton}" Margin="0,0,8,0"
                                                Command="{Binding RefreshStatusCommand}" MinWidth="100"/>
                                        <Button Content="Run sync" Style="{StaticResource PrimaryButton}"
                                                Command="{Binding RunSyncOnceCommand}" MinWidth="100"/>
                                    </StackPanel>
                                </Grid>

                                <Border Style="{StaticResource SettingsStatusBox}" Margin="0" VerticalAlignment="Stretch" MinHeight="160">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <TextBlock Text="{Binding PendingOutboxText}" Style="{StaticResource TextBody}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding CursorText}" Style="{StaticResource TextCaption}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding LastErrorText, StringFormat=Last error: {0}}"
                                                       Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            <TextBlock Text="Sync diagnostics (last pull)" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding SyncDiagnosticsText}" Style="{StaticResource TextCaption}"
                                                       TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding AutoSyncStatusText}" Style="{StaticResource TextCaption}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </DockPanel>
                        </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Receipt &amp; printing">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="0,8,0,0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Stretch">

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Store &amp; invoice header" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="Printed bill header, footer, and company details on receipts."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                <TextBlock Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"
                                           Text="Saved locally in %LocalAppData%\RRBridal\StoreBilling\receipt_config.json. Company profile syncs from central on Run sync."/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Store name" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptStoreName, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Branch code" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptBranchCode, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Phone" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptCustomerCarePhone, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Website" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="1" Grid.Column="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptWebsite, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="GSTIN" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptGstin, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="FSSAI no." Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="2" Grid.Column="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptFssaiNo, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Address" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Top" Margin="0,8,12,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptAddress, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="56" TextWrapping="Wrap" AcceptsReturn="True"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Terms" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Top" Margin="0,8,12,0"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptTerms, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="48" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Policy lines" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Top" Margin="0,8,12,0"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptPolicyLinesText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="48" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    <TextBlock Grid.Column="3" Text="Thank-you" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Top" Margin="0,8,12,0"/>
                                    <TextBox Grid.Column="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptThankYouLine, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Border Style="{StaticResource SettingsStatusBox}" Margin="0,8,0,12">
                                    <TextBlock Text="{Binding ReceiptCentralSyncText}" Style="{StaticResource TextCaption}" TextWrapping="Wrap"/>
                                </Border>
                                <Button Content="Reload from central" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left"
                                        Command="{Binding PullReceiptFromCentralCommand}" Margin="0,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Printer &amp; format" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ReceiptPrinterHintText}" Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding ReceiptPrinterWarningText}" Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource BrushWarning}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="Refresh printers" Style="{StaticResource OutlineButton}"
                                            Command="{Binding RefreshPrintersCommand}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Always use Windows print dialog" Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding ReceiptAlwaysUsePrintDialog}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Network printers (e.g. \\pos\Canon…) appear after Refresh."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                <TextBlock Text="Print format" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                <StackPanel Margin="0,0,0,12">
                                    <RadioButton Content="Thermal receipt (80mm)" GroupName="PrintFormat" Margin="0,0,0,6"
                                                 IsChecked="{Binding IsThermalReceiptFormat, Mode=TwoWay}"/>
                                    <RadioButton Content="A4 tax invoice" GroupName="PrintFormat" Margin="0,0,0,6"
                                                 IsChecked="{Binding IsA4ReceiptFormat, Mode=TwoWay}"/>
                                    <RadioButton Content="A5 tax invoice" GroupName="PrintFormat" Margin="0,0,0,0"
                                                 IsChecked="{Binding IsA5ReceiptFormat, Mode=TwoWay}"/>
                                </StackPanel>
                                <CheckBox Content="Use pre-printed A5 paper (values only)" Style="{StaticResource ThemedCheckBox}"
                                          IsChecked="{Binding A5PrePrintedEnabled}"
                                          Visibility="{Binding IsA5ReceiptFormat, Converter={StaticResource BoolToVis}}"
                                          Margin="0,0,0,6"/>
                                <TextBlock Text="Pre-printed A5: load branded stationery; app prints bill data on the form lines only."
                                           Visibility="{Binding IsA5ReceiptFormat, Converter={StaticResource BoolToVis}}"
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <Border Visibility="{Binding IsA5PrePrintedSettingsVisible, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,16" Padding="16" Background="{StaticResource BrushRowAlt}"
                                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="A5 pre-printed alignment (mm)" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                        <TextBlock TextWrapping="Wrap" Style="{StaticResource TextCaption}" Margin="0,0,0,12"
                                                   Text="All fields print by default (BILL TO, INV, DATE, CONTACT, stitching, D/D, lines, total). Saved with Save receipt settings."/>

                    <ScrollViewer MaxHeight="480" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Global" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Offset X" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.OffsetXMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Offset Y" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.OffsetYMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Table offset Y" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TableOffsetYMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Baseline nudge" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TextBaselineNudgeMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Row 1 — Bill To / Inv / Date" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="68"/>
                                    <ColumnDefinition Width="68"/>
                                    <ColumnDefinition Width="68"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Field" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Top" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Left" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Width" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Bill To" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.BillToTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.BillToLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.BillToWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Inv No" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.InvNoTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.InvNoLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.InvNoWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Date" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DateTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DateLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="3" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DateWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Row 2 — Contact / stitching / D/D" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="76"/>
                                    <ColumnDefinition Width="76"/>
                                    <ColumnDefinition Width="76"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Field" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Top" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Left" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="Width / size" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Contact" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.MetaRow2TopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ContactLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ContactWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Stitching tick" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.StitchingTickTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.StitchingTickLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.StitchingTickSizeMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="D/D date" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DeliveryDateTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DeliveryDateLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="3" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DeliveryDateWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Table" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Table top" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TableTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Row height" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.LineRowHeightMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Lines per page" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.MaxLineRows, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Text="Multi-page bills: page 1 shows Total Qty + Continued when more lines follow."
                                           TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="84"/>
                                    <ColumnDefinition Width="68"/>
                                    <ColumnDefinition Width="68"/>
                                    <ColumnDefinition Width="68"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Column" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Left" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Width" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Description" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ColDescLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ColDescWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Qty" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ColQtyLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ColQtyWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Rate" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ColRateLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ColRateWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Amount" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ColAmountLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,0"/>
                                <TextBox Grid.Row="4" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ColAmountWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Total" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TotalAmountLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TotalAmountTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TotalAmountWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Total Qty (page 1, multi-page only)" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TotalQtyLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TotalQtyTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Qty width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TotalQtyWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Continued (page 1, multi-page only)" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Label text" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ContinuedLabel, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <TextBlock Text="Row position follows last line + Total Qty. Left/width 0 = use Description column."
                                       FontSize="11" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ContinuedLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ContinuedWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Discount name (Discount 10%)" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountPercentLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountPercentTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Discount name width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountPercentWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Discount amount" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountAmountLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountAmountTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Discount amount width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountAmountWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Font" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Body pt" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.BodyFontPt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Total pt" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TotalFontPt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Font family" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource RoundedComboBox}"
                                          ItemsSource="{Binding A5FontFamilyOptions}"
                                          SelectedItem="{Binding A5Layout.PrintFontFamily, Mode=TwoWay}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Bill to max chars" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.BillToMaxChars, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Reset to defaults" Style="{StaticResource OutlineButton}"
                                Command="{Binding ResetA5PrePrintedLayoutToDefaultsCommand}" Margin="0,0,8,0"/>
                        <Button Content="Preview test layout" Style="{StaticResource OutlineButton}"
                                Command="{Binding PreviewA5PrePrintedAlignmentCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

                                <CheckBox Content="Also print thermal receipt first (80mm)" Style="{StaticResource ThemedCheckBox}"
                                          IsChecked="{Binding AlsoPrintThermalFirst}"
                                          Visibility="{Binding IsOfficeInvoiceFormat, Converter={StaticResource BoolToVis}}"
                                          Margin="0,0,0,8"/>
                                <TextBlock Text="Thermal: 80mm POS. A4/A5: office laser/inkjet — load matching paper in the tray."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Thermal printer (80mm)" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                        <ComboBox Style="{StaticResource RoundedComboBox}" ItemsSource="{Binding PrinterOptions}"
                                                  DisplayMemberPath="Display" SelectedValuePath="FullName"
                                                  SelectedValue="{Binding SelectedThermalPrinterFullName, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="A4 / A5 invoice printer" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                        <ComboBox Style="{StaticResource RoundedComboBox}" ItemsSource="{Binding PrinterOptions}"
                                                  DisplayMemberPath="Display" SelectedValuePath="FullName"
                                                  SelectedValue="{Binding SelectedOfficePrinterFullName, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Visibility="{Binding IsThermalReceiptFormat, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                                    <TextBlock Text="Receipt width (characters)" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                    <TextBlock Text="80mm thermal: use 48 chars; adjust if text wraps."
                                               Style="{StaticResource TextCaption}" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource SettingsNumericInput}" Text="{Binding ReceiptCharWidth, UpdateSourceTrigger=PropertyChanged}"
                                             Width="100" HorizontalAlignment="Left"/>
                                </StackPanel>

                                <Button Content="Save receipt settings" Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Left" Command="{Binding SaveReceiptSettingsCommand}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Other">
                <Grid Margin="0,8,0,0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*" MinWidth="280"/>
                    </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardBorder}" VerticalAlignment="Stretch">
                            <StackPanel>
                                <TextBlock Text="Duplicate bill print" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="Reprint posted invoices with DUPLICATE watermark (no stock change)."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                <CheckBox Content="Allow duplicate bill print (F11 / Duplicate / Ledger)"
                                          Style="{StaticResource ThemedCheckBox}"
                                          IsChecked="{Binding BillingAllowDuplicatePrint}" Margin="0,0,0,12"/>
                                <CheckBox Content="Allow cash payout of credit note remaining balance (Payment dialog)"
                                          Style="{StaticResource ThemedCheckBox}"
                                          IsChecked="{Binding BillingAllowCreditNoteRemainingCashout}" Margin="0,0,0,16"/>
                                <Button Content="Save settings" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                                        Command="{Binding SaveBillingSettingsCommand}"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardBorder}" VerticalAlignment="Stretch">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Developer tests" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Payment gateway and purchase intent test actions."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Content="PineLabs" Style="{StaticResource OutlineButton}" Margin="0,0,8,8"
                                                Command="{Binding TestPineLabsPaymentCommand}"/>
                                        <Button Content="Razorpay" Style="{StaticResource OutlineButton}" Margin="0,0,8,8"
                                                Command="{Binding TestRazorpayPaymentCommand}"/>
                                        <Button Content="Purchase intent" Style="{StaticResource OutlineButton}" Margin="0,0,0,8"
                                                Command="{Binding TestPurchaseIntentCommand}"/>
                                    </WrapPanel>
                                </StackPanel>
                                <Border Style="{StaticResource SettingsStatusBox}" Margin="0" VerticalAlignment="Stretch" MinHeight="120">
                                    <TextBlock Text="{Binding LastActionText}" Style="{StaticResource TextCaption}" TextWrapping="Wrap" VerticalAlignment="Top"/>
                                </Border>
                            </DockPanel>
                        </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
