                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Total Qty width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TotalQtyWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Continued (page 1, multi-page only)" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Label text" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ContinuedLabel, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <TextBlock Text="Row position follows last line + Total Qty. Left/width 0 = use Description column."
                                       FontSize="11" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ContinuedLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.ContinuedWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Discount name (Discount 10%)" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountPercentLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountPercentTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Discount name width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountPercentWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Discount amount" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountAmountLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountAmountTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Discount amount width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.DiscountAmountWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Alteration amount (below discount)" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Left" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.AlterationAmountLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="2" Text="Top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.AlterationAmountTopMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Alteration amount width" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.AlterationAmountWidthMm, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <TextBlock FontWeight="SemiBold" Text="Font" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="96"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Body pt" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.BodyFontPt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Total pt" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.TotalFontPt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Font family" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource RoundedComboBox}"
                                          ItemsSource="{Binding A5FontFamilyOptions}"
                                          SelectedItem="{Binding A5Layout.PrintFontFamily, Mode=TwoWay}" Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Bill to max chars" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A5Layout.BillToMaxChars, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Reset to defaults" Style="{StaticResource OutlineButton}"
                                Command="{Binding ResetA5PrePrintedLayoutToDefaultsCommand}" Margin="0,0,8,0"/>
                        <Button Content="Preview test layout" Style="{StaticResource OutlineButton}"
                                Command="{Binding PreviewA5PrePrintedAlignmentCommand}" Margin="0,0,8,0"/>
                        <Button Content="Preview duplicate layout" Style="{StaticResource OutlineButton}"
                                Command="{Binding PreviewA5PrePrintedDuplicateAlignmentCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

                                <CheckBox Content="Also print thermal receipt first (80mm)" Style="{StaticResource ThemedCheckBox}"
                                          IsChecked="{Binding AlsoPrintThermalFirst}"
                                          Visibility="{Binding IsOfficeInvoiceFormat, Converter={StaticResource BoolToVis}}"
                                          Margin="0,0,0,8"/>
                                <TextBlock Text="Thermal: 80mm POS. A4/A5: office laser/inkjet — load matching paper in the tray."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Thermal printer (80mm)" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                        <ComboBox Style="{StaticResource RoundedComboBox}" ItemsSource="{Binding PrinterOptions}"
                                                  DisplayMemberPath="Display" SelectedValuePath="FullName"
                                                  SelectedValue="{Binding SelectedThermalPrinterFullName, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="A4 / A5 invoice printer" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                        <ComboBox Style="{StaticResource RoundedComboBox}" ItemsSource="{Binding PrinterOptions}"
                                                  DisplayMemberPath="Display" SelectedValuePath="FullName"
                                                  SelectedValue="{Binding SelectedOfficePrinterFullName, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Visibility="{Binding IsThermalReceiptFormat, Converter={StaticResource BoolToVis}}" Margin="0,0,0,16">
                                    <TextBlock Text="Receipt width (characters)" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                    <TextBlock Text="80mm thermal: use 48 chars; adjust if text wraps."
                                               Style="{StaticResource TextCaption}" Margin="0,0,0,6"/>
                                    <TextBox Style="{StaticResource SettingsNumericInput}" Text="{Binding ReceiptCharWidth, UpdateSourceTrigger=PropertyChanged}"
                                             Width="100" HorizontalAlignment="Left"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Preview sample invoice" Style="{StaticResource OutlineButton}"
                                            Command="{Binding PreviewReceiptSettingsCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Preview credit receipt" Style="{StaticResource OutlineButton}"
                                            Command="{Binding PreviewCreditReceiptSettingsCommand}" Margin="0,0,8,0"/>
                                    <Button Content="Save receipt settings" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding SaveReceiptSettingsCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="3. WhatsApp">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,8,0,0">
                    <UniformGrid HorizontalAlignment="Stretch"
                                 ui:UniformGridColumnsBehavior.IsEnabled="True"
                                 ui:UniformGridColumnsBehavior.CompactColumns="1"
                                 ui:UniformGridColumnsBehavior.MediumColumns="2"
                                 ui:UniformGridColumnsBehavior.WideColumns="2">
                        <Border Style="{StaticResource SettingsGridCard}">
                            <StackPanel>
                                <TextBlock Text="WhatsApp bill delivery" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="Sends thermal bill image via WhatsApp Business API after billing (when enabled). API credentials are configured in Central admin."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <TextBlock Text="Connection status" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding WhatsAppConnectionStatus}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="Template" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                                <TextBlock Text="{Binding WhatsAppTemplateSummary}" Margin="0,0,0,12"/>
                                <CheckBox Content="Auto-send bill on post (when customer phone is present)"
                                          Style="{StaticResource ThemedCheckBox}"
                                          IsChecked="{Binding WhatsAppAutoSendAfterPost}" Margin="0,0,0,12"/>
                                <WrapPanel>
                                    <Button Content="Save WhatsApp settings" Style="{StaticResource PrimaryButton}"
                                            Command="{Binding SaveWhatsAppSettingsAsync}" Margin="0,0,8,8"/>
                                    <Button Content="Refresh status" Style="{StaticResource OutlineButton}" Margin="0,0,0,8"
                                            Command="{Binding RefreshWhatsAppStatusAsync}"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsGridCard}">
                            <StackPanel>
                                <TextBlock Text="Test send" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="Send a sample bill image to verify Meta template and credentials."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                <TextBlock Text="Test mobile" Style="{StaticResource FilterFieldLabel}"/>
                                <TextBox Style="{StaticResource SettingsFieldInput}"
                                         Text="{Binding WhatsAppTestPhone, UpdateSourceTrigger=PropertyChanged}" MaxWidth="280" HorizontalAlignment="Left"/>
                                <Button Content="Send test WhatsApp bill" Style="{StaticResource OutlineButton}"
                                        HorizontalAlignment="Left" Command="{Binding TestWhatsAppSendAsync}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="4. App &amp; billing">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Margin="0,8,0,0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <StackPanel>
                        <UniformGrid HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                     ui:UniformGridColumnsBehavior.IsEnabled="True"
                                     ui:UniformGridColumnsBehavior.CompactColumns="1"
                                     ui:UniformGridColumnsBehavior.MediumColumns="2"
                                     ui:UniformGridColumnsBehavior.WideColumns="3">

                            <Border Style="{StaticResource SettingsGridCard}">
                                <StackPanel>
                                    <TextBlock Text="Appearance &amp; navigation" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Choose how you open screens. Header menu keeps the workspace wider; sidebar is Tally-style."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                    <CheckBox Content="Show left sidebar menu"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding UiShowSidebarMenu}" Margin="0,0,0,6"/>
                                    <TextBlock Text="Off = quick links in the header bar. On = persistent left menu. Ctrl+G opens Go To."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                    <Button Content="Save appearance" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                                            Command="{Binding SaveUiSettingsCommand}" MinWidth="140"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGridCard}">
                                <StackPanel>
                                    <TextBlock Text="Billing behaviour" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Duplicate print, product scan confirmations, returns, and alteration tax."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                    <CheckBox Content="Allow duplicate bill print (F11 / Duplicate / Ledger)"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding BillingAllowDuplicatePrint}" Margin="0,0,0,10"/>
                                    <CheckBox Content="Confirm when the same product is added again"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding BillingConfirmDuplicateProductAdd}" Margin="0,0,0,4"/>
                                    <TextBlock Text="When off, scanning the same SKU increases quantity immediately."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <CheckBox Content="Allow cash payout of credit note remaining balance"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding BillingAllowCreditNoteRemainingCashout}" Margin="0,0,0,10"/>
                                    <CheckBox Content="Allow multiple returns per bill (partial returns)"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding BillingAllowMultipleReturnsPerBill}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Fully returned lines cannot be selected again in a later return."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <CheckBox Content="Alteration amount is GST inclusive"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding BillingAlterationGstIncluded}" Margin="0,0,0,4"/>
                                    <TextBlock Text="When off, alteration is a flat charge after merchandise tax."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                    <TextBlock Text="Line item columns" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                    <ComboBox HorizontalAlignment="Stretch" Margin="0,0,0,4"
                                              ItemsSource="{Binding BillingLineItemDetailOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Level"
                                              SelectedValue="{Binding BillingLineItemDetailLevel}"/>
                                    <TextBlock Text="{Binding BillingLineItemDetailDescription}"
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,4,0,0"
                                               Foreground="{StaticResource BrushTextMuted}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGridCard}">
                                <StackPanel>
                                    <TextBlock Text="Credit billing (pay later)" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Advance at post with remaining balance collected later from Credit Bills."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                    <CheckBox Content="Enable bill on credit"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding BillingEnableCreditBilling}" Margin="0,0,0,8"/>
                                    <CheckBox Content="Require credit customer flag"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding BillingCreditRequireCreditCustomer}" Margin="0,0,0,8"/>
                                    <CheckBox Content="Allow zero advance (full amount on credit)"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding BillingCreditAllowZeroAdvance}" Margin="0,0,0,8"/>
                                    <CheckBox Content="Allow partial collection after post"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding BillingCreditAllowPartialCollection}" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                            <TextBlock Text="Min advance %" Style="{StaticResource FilterFieldLabel}"/>
                                            <TextBox Style="{StaticResource SettingsFieldInput}"
                                                     Text="{Binding BillingCreditMinAdvancePercentText, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,8">
                                            <TextBlock Text="Min advance ₹" Style="{StaticResource FilterFieldLabel}"/>
                                            <TextBox Style="{StaticResource SettingsFieldInput}"
                                                     Text="{Binding BillingCreditMinAdvanceAmountText, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                                            <TextBlock Text="Max balance ₹ (0 = none)" Style="{StaticResource FilterFieldLabel}"/>
                                            <TextBox Style="{StaticResource SettingsFieldInput}"
                                                     Text="{Binding BillingCreditMaxBalancePerBillText, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGridCard}">
                                <StackPanel>
                                    <TextBlock Text="Razorpay POS (card / UPI device)" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Wired Ezetap / Razorpay POS Bridge credentials for this counter."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <CheckBox Content="Enable Razorpay POS payments"
                                              Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding RazorpayPosEnabled}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding RazorpayPosStatusText}"
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap"
                                               Foreground="{StaticResource BrushAccent}" Margin="0,0,0,12"/>
                                    <TextBlock Text="Username" Style="{StaticResource FilterFieldLabel}"/>
                                    <TextBox Style="{StaticResource SettingsFieldInput}" Text="{Binding RazorpayPosUsername, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="App key" Style="{StaticResource FilterFieldLabel}"/>
                                    <TextBox Style="{StaticResource SettingsFieldInput}" Text="{Binding RazorpayPosAppKey, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="API base URL" Style="{StaticResource FilterFieldLabel}"/>
                                    <TextBox Style="{StaticResource SettingsFieldInput}" Text="{Binding RazorpayPosApiBaseUrl, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="Device ID (pushTo)" Style="{StaticResource FilterFieldLabel}"/>
                                    <TextBox Style="{StaticResource SettingsFieldInput}" Text="{Binding RazorpayPosDeviceId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Example: 3170046844|ezetap_android — device must show Paired."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <Button Content="Save Razorpay POS" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left"
                                            Command="{Binding SaveRazorpayPosSettingsCommand}"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingsGridCard}">
                                <StackPanel>
                                    <TextBlock Text="Developer tests" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Payment gateway and purchase intent probes for this counter."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Content="PineLabs" Style="{StaticResource OutlineButton}" Margin="0,0,8,8"
                                                Command="{Binding TestPineLabsPaymentCommand}"/>
                                        <Button Content="Razorpay" Style="{StaticResource OutlineButton}" Margin="0,0,8,8"
                                                Command="{Binding TestRazorpayPaymentCommand}"/>
                                        <Button Content="Purchase intent" Style="{StaticResource OutlineButton}" Margin="0,0,0,8"
                                                Command="{Binding TestPurchaseIntentCommand}"/>
                                    </WrapPanel>
                                    <Border Style="{StaticResource SettingsStatusBox}" Margin="0">
                                        <TextBlock Text="{Binding LastActionText}" Style="{StaticResource TextCaption}" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource ActionFooterCard}" Margin="0,4,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding LastActionText}" Style="{StaticResource TextCaption}"
                                           TextWrapping="Wrap" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="Save billing settings" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding SaveBillingSettingsCommand}" MinWidth="170"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
