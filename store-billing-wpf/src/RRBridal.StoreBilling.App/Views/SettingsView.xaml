<UserControl x:Class="RRBridal.StoreBilling.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="720"
             Loaded="SettingsView_OnLoaded"
             FontFamily="{StaticResource FontFamilyPrimary}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="{StaticResource BrushBackground}">
    <UserControl.Resources>
        <Style x:Key="SettingsFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource TextLabel}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,10,8"/>
        </Style>
        <Style x:Key="SettingsFieldInput" TargetType="TextBox" BasedOn="{StaticResource RoundedTextBox}">
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="SettingsNumericInput" TargetType="TextBox" BasedOn="{StaticResource RoundedTextBox}">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="MinHeight" Value="{DynamicResource DensityInputMinHeight}"/>
            <Setter Property="Padding" Value="{DynamicResource DensityInputPadding}"/>
            <Setter Property="FontSize" Value="{DynamicResource DensityInputFontSize}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SettingsStatusBox" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BrushRowAlt}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="SettingsGridCard" TargetType="Border" BasedOn="{StaticResource CardBorder}">
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Settings" Style="{StaticResource TextPageTitleAccent}"/>
            <TextBlock Text="Sync, printing, WhatsApp, appearance, and billing options — organised by section."
                       Style="{StaticResource PageSubtitle}"/>
        </StackPanel>

        <TabControl Grid.Row="1" Style="{StaticResource ThemedTabControl}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                    SelectionChanged="SettingsTabs_OnSelectionChanged">
            <TabItem Header="1. Sync">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="0,8,0,0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <UniformGrid HorizontalAlignment="Stretch"
                                 ui:UniformGridColumnsBehavior.IsEnabled="True"
                                 ui:UniformGridColumnsBehavior.CompactColumns="1"
                                 ui:UniformGridColumnsBehavior.MediumColumns="2"
                                 ui:UniformGridColumnsBehavior.WideColumns="2">

                        <!-- Store sync actions + status -->
                        <Border Style="{StaticResource SettingsGridCard}">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Store sync" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Push local bills and pull master data from central."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                                    <WrapPanel Margin="0,0,0,14">
                                        <Button Content="Refresh" Style="{StaticResource OutlineButton}" Margin="0,0,8,8"
                                                Command="{Binding RefreshStatusCommand}" MinWidth="88"/>
                                        <Button Content="Re-sync products" Style="{StaticResource OutlineButton}" Margin="0,0,8,8"
                                                Command="{Binding ForceProductResyncCommand}" MinWidth="120"
                                                ToolTip="Reset product cursor and pull the full central catalog again (fills missing prices on stock stubs)."/>
                                        <Button Content="Run sync" Style="{StaticResource PrimaryButton}" Margin="0,0,0,8"
                                                Command="{Binding RunSyncOnceCommand}" MinWidth="88"/>
                                    </WrapPanel>
                                </StackPanel>
                                <Border Style="{StaticResource SettingsStatusBox}" Margin="0" VerticalAlignment="Stretch" MinHeight="120">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <TextBlock Text="{Binding PendingOutboxText}" Style="{StaticResource TextBody}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding CursorText}" Style="{StaticResource TextCaption}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding LastErrorText, StringFormat=Last error: {0}}"
                                                       Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                            <TextBlock Text="Sync diagnostics (last pull)" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding SyncDiagnosticsText}" Style="{StaticResource TextCaption}"
                                                       TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding AutoSyncStatusText}" Style="{StaticResource TextCaption}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding MongoHealthStatusText}" Style="{StaticResource TextCaption}"
                                                       TextWrapping="Wrap" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </DockPanel>
                        </Border>

                        <!-- Central auth -->
                        <Border Style="{StaticResource SettingsGridCard}">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Central connection" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Authenticate this counter with the central backend."
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                                    <Grid Margin="0,0,0,4"
                                          ui:ResponsiveFormGridBehavior.IsEnabled="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Email" Style="{StaticResource SettingsFieldLabel}"/>
                                        <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                                 Text="{Binding LoginEmail, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Password" Style="{StaticResource SettingsFieldLabel}"/>
                                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                                 Text="{Binding LoginPassword, UpdateSourceTrigger=PropertyChanged}"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,14">
                                        <Button Content="Login" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"
                                                Command="{Binding LoginCentralCommand}" MinWidth="88"/>
                                        <Button Content="Logout" Style="{StaticResource OutlineButton}"
                                                Command="{Binding LogoutCentralCommand}" MinWidth="88"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Style="{StaticResource SettingsStatusBox}" Margin="0" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding AuthStatusText}" Style="{StaticResource TextBody}" FontWeight="SemiBold"/>
                                </Border>
                            </DockPanel>
                        </Border>
                    </UniformGrid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="2. Printing">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              Padding="0,8,0,0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Stretch">

                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="Store &amp; invoice header" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="Printed bill header, footer, and company details on receipts."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                                <TextBlock Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"
                                           Text="Saved locally in %LocalAppData%\RRBridal\StoreBilling\receipt_config.json. Company profile syncs from central on Run sync."/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Store name" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptStoreName, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Branch code" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptBranchCode, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Phone" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptCustomerCarePhone, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="Website" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="1" Grid.Column="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptWebsite, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="GSTIN" Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptGstin, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="FSSAI no." Style="{StaticResource SettingsFieldLabel}"/>
                                    <TextBox Grid.Row="2" Grid.Column="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptFssaiNo, UpdateSourceTrigger=PropertyChanged}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Address" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Top" Margin="0,8,12,0"/>
                                    <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptAddress, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="56" TextWrapping="Wrap" AcceptsReturn="True"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Terms" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Top" Margin="0,8,12,0"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptTerms, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="48" TextWrapping="Wrap" AcceptsReturn="True"/>
                                </Grid>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Policy lines" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Top" Margin="0,8,12,0"/>
                                    <TextBox Grid.Column="1" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptPolicyLinesText, UpdateSourceTrigger=PropertyChanged}"
                                             MinHeight="48" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    <TextBlock Grid.Column="3" Text="Thank-you" Style="{StaticResource SettingsFieldLabel}" VerticalAlignment="Top" Margin="0,8,12,0"/>
                                    <TextBox Grid.Column="4" Style="{StaticResource SettingsFieldInput}"
                                             Text="{Binding ReceiptThankYouLine, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <Border Style="{StaticResource SettingsStatusBox}" Margin="0,8,0,12">
                                    <TextBlock Text="{Binding ReceiptCentralSyncText}" Style="{StaticResource TextCaption}" TextWrapping="Wrap"/>
                                </Border>
                                <Button Content="Reload from central" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left"
                                        Command="{Binding PullReceiptFromCentralCommand}" Margin="0,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorder}" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Printer &amp; format" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding ReceiptPrinterHintText}" Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding ReceiptPrinterWarningText}" Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource BrushWarning}" TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="Refresh printers" Style="{StaticResource OutlineButton}"
                                            Command="{Binding RefreshPrintersCommand}" Margin="0,0,12,0"/>
                                    <CheckBox Content="Always use Windows print dialog" Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding ReceiptAlwaysUsePrintDialog}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Network printers (e.g. \\pos\Canon…) appear after Refresh."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,16"/>

                                <TextBlock Text="Print format" Style="{StaticResource TextLabel}" Margin="0,0,0,8"/>
                                <StackPanel Margin="0,0,0,12">
                                    <RadioButton Content="Thermal receipt (80mm)" GroupName="PrintFormat" Margin="0,0,0,6"
                                                 IsChecked="{Binding IsThermalReceiptFormat, Mode=TwoWay}"/>
                                    <RadioButton Content="A4 retail invoice" GroupName="PrintFormat" Margin="0,0,0,6"
                                                 IsChecked="{Binding IsA4ReceiptFormat, Mode=TwoWay}"/>
                                    <CheckBox Content="Use pre-printed A4 paper — Bilal Textiles (values only)" Style="{StaticResource ThemedCheckBox}"
                                              IsChecked="{Binding A4PrePrintedEnabled}"
                                              Visibility="{Binding IsA4ReceiptFormat, Converter={StaticResource BoolToVis}}"
                                              Margin="16,0,0,6"/>
                                    <TextBlock Text="Pre-printed A4: load Bilal stationery; app prints customer, bill no, date, line items, and total on the form only."
                                               Visibility="{Binding IsA4ReceiptFormat, Converter={StaticResource BoolToVis}}"
                                               Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="16,0,0,12"/>
                                    <RadioButton Content="A4 commercial invoice" GroupName="PrintFormat" Margin="0,0,0,6"
                                                 IsChecked="{Binding IsA4CommercialReceiptFormat, Mode=TwoWay}"/>
                                    <RadioButton Content="A5 tax invoice" GroupName="PrintFormat" Margin="0,0,0,0"
                                                 IsChecked="{Binding IsA5ReceiptFormat, Mode=TwoWay}"/>
                                </StackPanel>

                                <TextBlock Text="Credit bill receipt format" Style="{StaticResource TextLabel}" Margin="0,8,0,8"/>
                                <TextBlock Text="Applies to Bill on credit invoices and Credit Bills balance receipts (separate from normal invoice format)."
                                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <StackPanel Margin="0,0,0,12">
                                    <RadioButton Content="Thermal (80mm)" GroupName="CreditPrintFormat" Margin="0,0,0,6"
                                                 IsChecked="{Binding IsCreditThermalPrintFormat, Mode=TwoWay}"/>
                                    <RadioButton Content="A4 credit template" GroupName="CreditPrintFormat" Margin="0,0,0,0"
                                                 IsChecked="{Binding IsCreditA4PrintFormat, Mode=TwoWay}"/>
                                </StackPanel>
                                <Border Visibility="{Binding IsA4PrePrintedSettingsVisible, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,16" Padding="16" Background="{StaticResource BrushRowAlt}"
                                        BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock Text="A4 pre-printed alignment — Bilal Textiles (mm)" Style="{StaticResource TextSectionTitle}" Margin="0,0,0,4"/>
                                        <TextBlock TextWrapping="Wrap" Style="{StaticResource TextCaption}" Margin="0,0,0,12"
                                                   Text="Prints billing address, bill no, date, 11-column lines, and total on pre-printed Bilal A4 paper."/>
                                        <ScrollViewer MaxHeight="480" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock FontWeight="SemiBold" Text="Global" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="96"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="96"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Offset X" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                                    <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.OffsetXMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,4"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Offset Y" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                                    <TextBox Grid.Row="0" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.OffsetYMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Table offset Y" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.TableOffsetYMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,4"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Lines per page" VerticalAlignment="Center" Margin="0,0,8,4"/>
                                                    <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.MaxLineRows, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Body font pt" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.BodyFontPt, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Total font pt" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Row="2" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.TotalFontPt, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <TextBlock FontWeight="SemiBold" Text="Header — Billing / Bill No / Date / Order No" Margin="0,0,0,4"/>
                                                <TextBlock TextWrapping="Wrap" Style="{StaticResource TextCaption}" Margin="0,0,0,8"
                                                           Text="Bill no, date, and order no stack vertically in the right meta box (values after each label)."/>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="84"/>
                                                        <ColumnDefinition Width="68"/>
                                                        <ColumnDefinition Width="68"/>
                                                        <ColumnDefinition Width="68"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Field" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Top" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Left" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Width" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Billing" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.BillToTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                                    <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.BillToLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                                    <TextBox Grid.Row="1" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.BillToWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Bill No" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.InvNoTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                                    <TextBox Grid.Row="2" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.InvNoLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                                    <TextBox Grid.Row="2" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.InvNoWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Date" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="3" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.DateTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                                    <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.DateLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                                    <TextBox Grid.Row="3" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.DateWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Order No" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.OrderNoTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                                    <TextBox Grid.Row="4" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.OrderNoLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                                    <TextBox Grid.Row="4" Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.OrderNoWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Meta row height" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="5" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.MetaRowHeightMm, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <TextBlock FontWeight="SemiBold" Text="Table — first row top / row height" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="96"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="96"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="Table top" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.TableTopMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,12,0"/>
                                                    <TextBlock Grid.Column="2" Text="Row height" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Column="3" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.LineRowHeightMm, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <TextBlock FontWeight="SemiBold" Text="Table columns (left / width mm)" Margin="0,0,0,4"/>
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="68"/>
                                                        <ColumnDefinition Width="68"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Column" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Left" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Width" FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="SR" VerticalAlignment="Center"/>
                                                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.ColSrLeftMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,4,4"/>
                                                    <TextBox Grid.Row="1" Grid.Column="2" Style="{StaticResource SettingsNumericInput}" Text="{Binding A4Layout.ColSrWidthMm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Particular" VerticalAlignment="Center"/>
