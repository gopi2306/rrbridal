<UserControl x:Class="RRBridal.StoreBilling.App.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BrushBackground}">
    <Grid x:Name="MasterDetailGrid" Background="{StaticResource BrushBackground}"
          ui:MasterDetailLayoutBehavior.IsEnabled="True">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <Border Style="{StaticResource CardBorder}" Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,6">
                                <TextBlock Style="{StaticResource TextSectionTitle}" Text="Customer" VerticalAlignment="Center"/>
                                <Button Content="Find Customer" Style="{StaticResource OutlineButton}" Margin="12,0,0,0"
                                        Padding="10,4" FontSize="12" Command="{Binding SearchCustomerCommand}"/>
                                <Button Content="Resume held" Style="{StaticResource OutlineButton}" Margin="8,0,0,0"
                                        Padding="10,4" FontSize="12" Command="{Binding ResumeHeldBillsCommand}"/>
                            </StackPanel>
                            <WrapPanel Grid.Row="1">
                                <CheckBox Content="Hold bills" Style="{StaticResource ThemedCheckBox}" IsChecked="{Binding HoldBills}" Margin="0,0,12,4" VerticalAlignment="Center"/>
                                <CheckBox Content="Door delivery" Style="{StaticResource ThemedCheckBox}" IsChecked="{Binding DoorDelivery}" Margin="0,0,12,4" VerticalAlignment="Center"/>
                                <CheckBox Content="Online COD" Style="{StaticResource ThemedCheckBox}" IsChecked="{Binding OnlineCodOrder}" Margin="0,0,12,4" VerticalAlignment="Center"/>
                                <CheckBox Content="Stitching" Style="{StaticResource ThemedCheckBox}" IsChecked="{Binding Stitching}" Margin="0,0,12,4" VerticalAlignment="Center"/>
                                <CheckBox Content="Print invoice" Style="{StaticResource ThemedCheckBox}" IsChecked="{Binding PrintInvoice}" Margin="0,0,0,4" VerticalAlignment="Center"/>
                            </WrapPanel>
                        </Grid>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                                    Margin="0,0,0,6"
                                    Visibility="{Binding Stitching, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Delivery date" Style="{StaticResource FormFieldLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding DeliveryDate}" MinWidth="140" Height="28"/>
                        </StackPanel>
                        <Grid Grid.Row="2" ui:ResponsiveFormGridBehavior.IsEnabled="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Customer code" Style="{StaticResource FormFieldLabel}" Margin="0,0,0,4"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource RoundedTextBoxCompact}" Text="{Binding CustomerCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Salesman" Style="{StaticResource FormFieldLabel}" Margin="0,0,0,4"/>
                            <ComboBox Grid.Row="0" Grid.Column="4" Style="{StaticResource RoundedComboBox}"
                                      ItemsSource="{Binding ActiveSalesmen}"
                                      SelectedItem="{Binding SelectedSalesman}"
                                      DisplayMemberPath="DisplayLabel"
                                      IsEditable="False" Margin="0,0,0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Phone" Style="{StaticResource FormFieldLabel}"/>
                            <Border x:Name="PhoneInputBorder" Grid.Row="1" Grid.Column="1" Margin="0,0,0,0"
                                    CornerRadius="8" BorderThickness="2" BorderBrush="Transparent" SnapsToDevicePixels="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPhoneIncompleteHighlight}" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard x:Name="PhoneBlinkStoryboard">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="1" To="0.4" Duration="0:0:0.45" AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="PhoneBlinkStoryboard"/>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             To="1" Duration="0:0:0"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBox x:Name="CustomerPhoneBox" Style="{StaticResource RoundedTextBoxCompact}"
                                         Text="{Binding CustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="10"
                                         KeyDown="CustomerPhoneBox_OnKeyDown"
                                         LostFocus="CustomerPhoneBox_OnLostFocus"/>
                            </Border>

                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Customer name" Style="{StaticResource FormFieldLabel}"/>
                            <TextBox x:Name="CustomerNameBox" Grid.Row="1" Grid.Column="4"
                                     Style="{StaticResource RoundedTextBoxCompact}"
                                     Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="CustomerNameBox_OnKeyDown"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Style="{StaticResource TextSectionTitle}" Text="Line items" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Import CSV" Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Command="{Binding ImportCsvCommand}"/>
                                <Button Content="Add manual" Style="{StaticResource PrimaryButton}" Command="{Binding AddManualLineCommand}"/>
                            </StackPanel>
                        </Grid>
                        <DataGrid x:Name="LinesGrid"
                                  Grid.Row="1"
                                  ItemsSource="{Binding Lines}"
                                  Style="{StaticResource ThemedDataGrid}"
                                  SelectionUnit="Cell"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  RowHeight="36"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BrushBorder}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  PreparingCellForEdit="LinesGrid_OnPreparingCellForEdit"
                                  PreviewKeyDown="LinesGrid_OnPreviewKeyDown"
                                  CurrentCellChanged="LinesGrid_OnCurrentCellChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="S.No" Binding="{Binding LineNo}" IsReadOnly="True" Width="50"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn Header="Product code" Binding="{Binding ProductCode, UpdateSourceTrigger=PropertyChanged}" Width="110"
                                                    EditingElementStyle="{StaticResource ThemedDataGridCellTextBox}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource ThemedDataGridCellText}">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Description" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"
                                                    EditingElementStyle="{StaticResource ThemedDataGridCellTextBox}"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Qty, UpdateSourceTrigger=PropertyChanged}" Width="70"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"
                                                    EditingElementStyle="{StaticResource ThemedDataGridCellTextBox}"/>
                                <DataGridTextColumn x:Name="ColHsn" Header="HSN" Binding="{Binding HsnCode, UpdateSourceTrigger=PropertyChanged}" Width="90"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"
                                                    EditingElementStyle="{StaticResource ThemedDataGridCellTextBox}"/>
                                <DataGridTextColumn Header="Rate" Binding="{Binding Rate, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="90"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"
                                                    EditingElementStyle="{StaticResource ThemedDataGridCellTextBox}"/>
                                <DataGridTextColumn Header="Alteration amt" Binding="{Binding AlterationAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"
                                                    EditingElementStyle="{StaticResource ThemedDataGridCellTextBox}"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=N2}" IsReadOnly="True" Width="100"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColDisc" Header="Disc (₹)" Binding="{Binding DiscountAmount, StringFormat=N2}" IsReadOnly="True" Width="80"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColCashDisc" Header="Cash disc (₹)" Binding="{Binding CashDiscountAmount, StringFormat=N2}" IsReadOnly="True" Width="90"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColScheme" Header="Scheme (₹)" Binding="{Binding SchemeDiscountAmount, StringFormat=N2}" IsReadOnly="True" Width="90"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColOrigTax" Header="Orig tax (₹)" Binding="{Binding OriginalTaxAmount, StringFormat=N2}" IsReadOnly="True" Width="85"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColRevisedAmt" Header="Revised amt (₹)" Binding="{Binding RevisedAmount, StringFormat=N2}" IsReadOnly="True" Width="95"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColRevisedGst" Header="Revised GST (₹)" Binding="{Binding RevisedTaxAmount, StringFormat=N2}" IsReadOnly="True" Width="95"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColMrp" Header="MRP" Binding="{Binding Mrp, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="80"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"
                                                    EditingElementStyle="{StaticResource ThemedDataGridCellTextBox}"/>
                                <DataGridTextColumn x:Name="ColTaxPct" Header="Tax %" Binding="{Binding TaxPercent, UpdateSourceTrigger=PropertyChanged}" Width="60"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"
                                                    EditingElementStyle="{StaticResource ThemedDataGridCellTextBox}"/>
                                <DataGridTextColumn x:Name="ColCgst" Header="CGST%" Binding="{Binding CgstPercent}" IsReadOnly="True" Width="60"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColSgst" Header="SGST%" Binding="{Binding SgstPercent}" IsReadOnly="True" Width="60"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColIgst" Header="IGST%" Binding="{Binding IgstPercent}" IsReadOnly="True" Width="60"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTextColumn x:Name="ColTaxAmt" Header="Tax Amt" Binding="{Binding TaxAmount, StringFormat=N2}" IsReadOnly="True" Width="80"
                                                    ElementStyle="{StaticResource ThemedDataGridCellText}"/>
                                <DataGridTemplateColumn Header="" Width="48">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource IconDeleteButton}"
                                                    HorizontalAlignment="Center"
                                                    Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Row="2"
                                BorderBrush="{StaticResource BrushBorder}"
                                BorderThickness="1,0,1,1"
                                Background="{StaticResource BrushSurface}"
                                Padding="0,6">
                            <Grid MinHeight="28">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Grid.ColumnSpan="3"
                                           Text="Total qty"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,8,0"
                                           Foreground="{StaticResource BrushText}"/>
                                <TextBlock Grid.Column="3"
                                           Text="{Binding TotalLineQtyFormatted}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource BrushAccent}"/>
                            </Grid>
                        </Border>
                        <TextBlock Grid.Row="3" Margin="0,8,0,0" FontStyle="Italic" FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                                   Text="Last row Product code: scan/type SKU and Enter to add (Qty optional, default 1). Change Qty then Enter to jump to Product code. F3 focuses Product code."/>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Style="{StaticResource TotalsSidebarPanel}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource TotalsSidebarHeader}">
                    <StackPanel>
                        <TextBlock Text="INVOICE PREVIEW" Foreground="White" FontWeight="Bold" FontSize="12" Opacity="0.95"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Border Background="#33FFFFFF" CornerRadius="4" Padding="6,2">
                                <TextBlock Text="{Binding DraftLabel}" Foreground="White" FontSize="11"/>
                            </Border>
                            <TextBlock Text="{Binding HoldNo, StringFormat=HOLD NO: {0}}"
                                       Foreground="White" Margin="12,0,0,0"
                                       VerticalAlignment="Center" TextWrapping="Wrap">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HoldNo}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding BillNo, StringFormat=BILL NO: {0}}" Foreground="White" Margin="12,0,0,0"
                                       VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Text="{Binding BillDateDisplay}" Foreground="White" Opacity="0.9" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="14,12" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Sub total" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding SubTotalFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="GST before discount" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding OriginalTaxTotalFormatted}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Item discount" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding ItemDiscountFormatted}" HorizontalAlignment="Right" Foreground="{StaticResource BrushNegative}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Cash discount" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding CashDiscAmountFormatted}" HorizontalAlignment="Right" Foreground="{StaticResource BrushNegative}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Scheme / offer discount" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding SchemeDiscountFormatted}" HorizontalAlignment="Right" Foreground="{StaticResource BrushNegative}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Alteration amount" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding AlterationTotalFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <StackPanel Margin="0,0,0,8"
                                    Visibility="{Binding HasAppliedSchemes, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Applied schemes" FontWeight="SemiBold" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding AppliedSchemes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding SchemeName}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SavedAmountFormatted}" Margin="8,0,8,0"
                                                       Foreground="{StaticResource BrushNegative}"/>
                                            <Button Grid.Column="2" Content="Remove" Padding="6,2" FontSize="11"
                                                    Command="{Binding DataContext.RemoveAppliedSchemeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Revised sub total" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding RevisedSubTotalFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="CGST" Foreground="{StaticResource BrushTextMuted}"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                            <TextBlock Text="{Binding CgstTotalFormatted}" HorizontalAlignment="Right"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="SGST" Foreground="{StaticResource BrushTextMuted}"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                            <TextBlock Text="{Binding SgstTotalFormatted}" HorizontalAlignment="Right"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="IGST" Foreground="{StaticResource BrushTextMuted}"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding IgstTotalFormatted}" HorizontalAlignment="Right"
                                       Visibility="{Binding IsInterState, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Tax total" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding TaxTotalFormatted}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Total (incl. tax)" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding GrossTotalFormatted}" HorizontalAlignment="Right" Foreground="{StaticResource BrushText}" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="Round off" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding RoundOffFormatted}" HorizontalAlignment="Right" Foreground="{StaticResource BrushText}"/>
                        </Grid>

                        <StackPanel Margin="0,4,0,8"
                                    Visibility="{Binding HasAvailableCredit, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Customer credit" FontWeight="SemiBold" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding AvailableCreditNotes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding DisplayLabel}"
                                                Command="{Binding DataContext.ToggleCreditNoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource OutlineButton}">
                                                    <Setter Property="Padding" Value="10,6"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="Margin" Value="0,0,6,6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Grid Margin="0,0,0,6"
                              Visibility="{Binding HasAppliedCredit, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Credit note" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding SelectedCreditNoteLabel}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"
                              Visibility="{Binding HasAppliedCredit, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Original balance" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding OriginalCreditBalanceFormatted}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"
                              Visibility="{Binding HasAppliedCredit, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Payable before credit" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding PayableBeforeCreditFormatted}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"
                              Visibility="{Binding HasAppliedCredit, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Applied on this bill" Foreground="{StaticResource BrushAccent}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CreditAppliedFormatted}" HorizontalAlignment="Right"
                                       Foreground="{StaticResource BrushAccent}" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid Margin="0,0,0,6"
                              Visibility="{Binding HasAppliedCredit, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Remaining after bill" Foreground="{StaticResource BrushTextMuted}"/>
                            <TextBlock Text="{Binding RemainingAfterCreditFormatted}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>

                        <Separator Margin="0,8,0,12"/>

                        <CheckBox Content="Inter-state (IGST)" Style="{StaticResource ThemedCheckBox}"
                                  IsChecked="{Binding IsInterState}" Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding MaxDiscountPercentHint}"
                                   Visibility="{Binding ShowMaxDiscountHint, Converter={StaticResource BoolToVis}}"
                                   Foreground="{StaticResource BrushTextMuted}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Item discount (%)" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}"
                                     Text="{Binding ItemDiscountPercentText, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="EditableAmountBox_OnGotFocus"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Cash disc amt" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}"
                                     Text="{Binding CashDiscAmountText, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="EditableAmountBox_OnGotFocus"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Round off" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}"
                                     Text="{Binding RoundOffText, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="EditableAmountBox_OnGotFocus"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="{StaticResource BrushAccent}" CornerRadius="0,0,12,12" Padding="14,14">
                    <Grid>
                        <TextBlock Text="Payable" Foreground="White" Opacity="0.9" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PayableTotalFormatted}" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
