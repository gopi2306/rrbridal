<UserControl x:Class="RRBridal.StoreBilling.App.Views.Placeholders.DashboardPlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border Style="{StaticResource CardBorder}" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520" Margin="16">
            <StackPanel>
                <TextBlock Text="Dashboard" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}"/>
                <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{StaticResource BrushTextMuted}"
                           Text="Store summary and quick metrics will appear here. This page is not implemented yet."/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
