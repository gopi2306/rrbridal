<UserControl x:Class="RRBridal.StoreBilling.App.Views.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="240"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Analytics" Style="{StaticResource TextPageTitleAccent}"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Store: " Style="{StaticResource PageSubtitle}" Margin="0"/>
                    <TextBlock Text="{Binding StoreIdDisplay, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource BrushText}" FontSize="11.5" Margin="2,0,0,0"/>
                    <TextBlock Text=" · " Style="{StaticResource PageSubtitle}" Margin="0"/>
                    <TextBlock Text="{Binding PeriodSummary}" Style="{StaticResource PageSubtitle}" Margin="0"/>
                </StackPanel>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Content="Refresh" Style="{StaticResource OutlineButton}"
                    Command="{Binding RefreshCommand}" MinWidth="110"/>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,10"/>

            <UniformGrid ui:UniformGridColumnsBehavior.IsEnabled="True"
                         ui:UniformGridColumnsBehavior.CompactColumns="1"
                         ui:UniformGridColumnsBehavior.MediumColumns="3"
                         ui:UniformGridColumnsBehavior.WideColumns="3">
                <Border Style="{StaticResource MetricCardAccent}">
                    <StackPanel>
                        <TextBlock Text="Bills in period" Style="{StaticResource FilterFieldLabel}"/>
                        <TextBlock Text="{Binding PeriodBillsCount}" Style="{StaticResource MetricValueAccent}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="Revenue in period" Style="{StaticResource FilterFieldLabel}"/>
                        <TextBlock Text="{Binding PeriodRevenue}" Style="{StaticResource MetricValue}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource MetricCard}">
                    <StackPanel>
                        <TextBlock Text="Average bill" Style="{StaticResource FilterFieldLabel}"/>
                        <TextBlock Text="{Binding PeriodAvgBill}" Style="{StaticResource MetricValue}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <TextBlock Margin="0,10,0,0" Style="{StaticResource TextCaption}" TextWrapping="Wrap"
                       Text="Daily breakdown uses posted bills in local MongoDB (store_bills), keyed by posted time in UTC."/>
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="8" VerticalAlignment="Stretch">
            <DataGrid ItemsSource="{Binding DailyRows}"
                      Style="{StaticResource ThemedDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Day (UTC)" Binding="{Binding DayLabel}" Width="*"/>
                    <DataGridTextColumn Header="Bills" Binding="{Binding BillsCount}" Width="80"/>
                    <DataGridTextColumn Header="Revenue" Binding="{Binding Revenue, StringFormat=₹ {0:N2}}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
