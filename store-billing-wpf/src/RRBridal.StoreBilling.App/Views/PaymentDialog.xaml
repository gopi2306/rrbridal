<Window x:Class="RRBridal.StoreBilling.App.Views.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RRBridal.StoreBilling.App.ViewModels"
        Title="Payment" SizeToContent="Height" Width="640" MinWidth="560" MaxHeight="900"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">

    <Window.Resources>
        <Style x:Key="ModeRadio" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="24,20" LastChildFill="True">
        <Grid DockPanel.Dock="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Error message -->
            <TextBlock Grid.Row="0" Text="{Binding ErrorMessage}" FontSize="13" Foreground="{StaticResource BrushNegative}"
                       TextWrapping="Wrap" Margin="0,0,0,12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:PaymentStatus.Failed}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Action buttons -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Processing payment..." FontSize="13" Foreground="{StaticResource BrushTextMuted}" FontStyle="Italic"/>
                </StackPanel>

                <Button Grid.Column="1" Style="{StaticResource OutlineButton}" Content="Cancel" Margin="0,0,10,0" MinWidth="90"
                        Command="{Binding CancelCommand}"
                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>

                <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Content="Confirm Payment" MinWidth="140"
                        Command="{Binding ConfirmPaymentCommand}"
                        IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
            </Grid>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header: invoice total and amount to collect -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="Invoice total" FontSize="13" Foreground="{StaticResource BrushTextMuted}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding PayableFormatted}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource BrushText}"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        <TextBlock Text="Credit applied" FontSize="12" Foreground="{StaticResource BrushTextMuted}" HorizontalAlignment="Center"
                                   Margin="0,10,0,2"
                                   Visibility="{Binding HasPaymentCreditApplied, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding PaymentCreditAppliedFormatted}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}"
                                   HorizontalAlignment="Center"
                                   Visibility="{Binding HasPaymentCreditApplied, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="Amount to collect" FontSize="13" Foreground="{StaticResource BrushTextMuted}" HorizontalAlignment="Center"
                                   Margin="0,10,0,2"/>
                        <TextBlock Text="{Binding CollectibleFormatted}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource BrushAccent}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="{Binding BillingCreditReservedBanner}" FontSize="13" Foreground="{StaticResource BrushAccent}"
                                   TextWrapping="Wrap" Margin="0,0,0,8"
                                   Visibility="{Binding HasBillingCreditReserved, Converter={StaticResource BoolToVis}}"/>

                        <StackPanel Visibility="{Binding HasAvailableCredit, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Customer credit" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding AvailableCreditNotes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding DisplayLabel}"
                                                Command="{Binding DataContext.TogglePaymentCreditNoteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource OutlineButton}">
                                                    <Setter Property="Padding" Value="10,6"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="Margin" Value="0,0,6,6"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BrushAccent}"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Credit note" FontSize="12" Foreground="{StaticResource BrushTextMuted}"
                                           Visibility="{Binding HasPaymentCreditSelected, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPaymentCreditLabel}" FontSize="12" FontWeight="SemiBold"
                                           Visibility="{Binding HasPaymentCreditSelected, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Original balance" FontSize="12" Foreground="{StaticResource BrushTextMuted}"
                                           Visibility="{Binding HasPaymentCreditSelected, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PaymentOriginalCreditFormatted}" FontSize="12"
                                           Visibility="{Binding HasPaymentCreditSelected, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Using on payment" FontSize="12" Foreground="{StaticResource BrushAccent}"
                                           Visibility="{Binding HasPaymentCreditSelected, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PaymentApplyingCreditFormatted}" FontSize="12" FontWeight="SemiBold"
                                           Visibility="{Binding HasPaymentCreditSelected, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Remaining after" FontSize="12" Foreground="{StaticResource BrushTextMuted}"
                                           Visibility="{Binding HasPaymentCreditSelected, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PaymentRemainingAfterFormatted}" FontSize="12" FontWeight="SemiBold"
                                           Visibility="{Binding HasPaymentCreditSelected, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                            <StackPanel Margin="0,10,0,0"
                                        Visibility="{Binding CanCashOutCreditNote, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Cash out remaining" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CreditNoteCashOutMaxFormatted}" FontSize="11" Foreground="{StaticResource BrushAccent}" Margin="0,0,0,6"/>
                                <TextBox Style="{StaticResource RoundedTextBox}"
                                         Text="{Binding CreditNoteCashOutAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                         MinHeight="36" Padding="10,8"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Payment Mode Selection -->
                <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Payment Method" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,10"/>
                        <WrapPanel>
                            <RadioButton Style="{StaticResource ModeRadio}" Content="Cash"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Cash}"
                                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                            <RadioButton Style="{StaticResource ModeRadio}" Content="{Binding CardModeLabel}"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Card}"
                                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                            <RadioButton Style="{StaticResource ModeRadio}" Content="{Binding UpiModeLabel}"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Upi}"
                                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                            <RadioButton Style="{StaticResource ModeRadio}" Content="Credit Note"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=CreditNote}"
                                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                            <RadioButton Style="{StaticResource ModeRadio}" Content="Split Payment"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Split}"
                                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                            <RadioButton Style="{StaticResource ModeRadio}" Content="Bill on credit"
                                         IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Credit}"
                                         IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"
                                         Visibility="{Binding ShowCreditBillingOption, Converter={StaticResource BoolToVis}}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Mode-specific panels -->
                <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0,0,0,12" MinHeight="118">
                    <Grid>
                <!-- Cash Panel -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.Cash}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Amount received (to collect)" FontSize="13" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
                        <TextBox Grid.Row="1" Grid.Column="0" Style="{StaticResource RoundedTextBox}" FontSize="18" FontWeight="Bold" Margin="0,0,12,0"
                                 Text="{Binding AmountReceived, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Change Due" FontSize="13" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
                        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource BrushBackground}" CornerRadius="8" Padding="10,8">
                            <TextBlock Text="{Binding ChangeDueFormatted}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FF2E7D32"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCashShortfall}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource BrushNegative}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Card Panel -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.Card}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding CardPaymentTitle}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding CardPaymentHelpText}" FontSize="13" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Border Background="{StaticResource BrushBackground}" CornerRadius="8" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Status:" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding DeviceStatusText}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- UPI Panel -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.Upi}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding UpiPaymentTitle}" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding UpiPaymentHelpText}" FontSize="13" Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    <Border Background="{StaticResource BrushBackground}" CornerRadius="8" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Status:" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding DeviceStatusText}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Credit Note Panel -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.CreditNote}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Credit Note" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Record credit note payment (amount capped by note balance minus invoice credit already applied)." FontSize="13" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
                    <TextBlock Text="{Binding CreditNoteMaxFormatted}" FontSize="12" Foreground="{StaticResource BrushAccent}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Credit note no. / reference" FontSize="13" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Amount" FontSize="13" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
                        <TextBox Grid.Row="1" Grid.Column="0" Style="{StaticResource RoundedTextBox}" Margin="0,0,12,0"
                                 Text="{Binding CreditNoteReference, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource RoundedTextBox}" FontWeight="SemiBold"
                                 Text="{Binding CreditNoteAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                    </Grid>
                </StackPanel>

                <!-- Split Panel -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.Split}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Remaining:" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding SplitRemainingFormatted}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource BrushNegative}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSplitBalanced}" Value="True">
                                            <Setter Property="Foreground" Value="#FF2E7D32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Cash" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,8"
                                 Text="{Binding SplitCashAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Card (Razorpay POS)" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,8"
                                 Text="{Binding SplitCardAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="UPI (Razorpay POS)" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,8"
                                 Text="{Binding SplitUpiAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Credit Note" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Margin="0,0,8,8"
                                 Text="{Binding SplitCreditNoteAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource RoundedTextBox}">
                                    <Setter Property="IsEnabled" Value="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPaymentCreditSelected}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                        <TextBox Grid.Row="3" Grid.Column="2" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,8"
                                 ToolTip="Reference when credit note amount is used"
                                 Text="{Binding SplitCreditNoteReference, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>

                        <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Text="Reference (required if credit note amount &gt; 0)"
                                   FontSize="11" Foreground="{StaticResource BrushTextMuted}"/>
                    </Grid>
                </StackPanel>

                <!-- Bill on credit panel -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.Credit}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Bill on credit — collect advance now, balance later"
                               FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock Text="{Binding CreditBillingHint}" FontSize="11" Foreground="{StaticResource BrushTextMuted}"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Advance now (₹)" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource RoundedTextBox}"
                                     Text="{Binding CreditAdvanceAmountText, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Balance on credit" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding CreditBalanceDueFormatted}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushAccent}"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Advance payment mode" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,12,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Cash" Margin="0,0,16,0"
                                     IsChecked="{Binding CreditAdvanceMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Cash}"/>
                        <RadioButton Content="Card" Margin="0,0,16,0"
                                     IsChecked="{Binding CreditAdvanceMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Card}"/>
                        <RadioButton Content="UPI"
                                     IsChecked="{Binding CreditAdvanceMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Upi}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
            </Grid>
        </ScrollViewer>
    </DockPanel>
</Window>
