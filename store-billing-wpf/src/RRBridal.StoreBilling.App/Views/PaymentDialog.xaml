<Window x:Class="RRBridal.StoreBilling.App.Views.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RRBridal.StoreBilling.App.ViewModels"
        xmlns:pay="clr-namespace:RRBridal.StoreBilling.App.Services.Payments"
        Title="Payment" SizeToContent="Height" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BrushBackground}">

    <Window.Resources>
        <Style x:Key="ModeRadio" TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: Payable total -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Total Payable" FontSize="13" Foreground="{StaticResource BrushTextMuted}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding PayableFormatted}" FontSize="32" FontWeight="Bold" Foreground="{StaticResource BrushAccent}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Payment Mode Selection -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Payment Method" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,10"/>
                <WrapPanel>
                    <RadioButton Style="{StaticResource ModeRadio}" Content="Cash"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Cash}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                    <RadioButton Style="{StaticResource ModeRadio}" Content="Card (POS)"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Card}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                    <RadioButton Style="{StaticResource ModeRadio}" Content="UPI (Razorpay)"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Upi}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                    <RadioButton Style="{StaticResource ModeRadio}" Content="Split Payment"
                                 IsChecked="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Split}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Mode-specific panels -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0,0,0,12" MinHeight="100">
            <Grid>
                <!-- Cash Panel -->
                <StackPanel Visibility="{Binding SelectedMode, Converter={StaticResource EnumBoolConverter}, ConverterParameter=Cash}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.Cash}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Amount Received" FontSize="13" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
                        <TextBox Grid.Row="1" Grid.Column="0" Style="{StaticResource RoundedTextBox}" FontSize="18" FontWeight="Bold" Margin="0,0,12,0"
                                 Text="{Binding AmountReceived, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                 IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>

                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Change Due" FontSize="13" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,6"/>
                        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource BrushBackground}" CornerRadius="8" Padding="10,8">
                            <TextBlock Text="{Binding ChangeDueFormatted}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FF2E7D32"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCashShortfall}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource BrushNegative}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Card Panel -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.Card}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="POS Device (PineLabs)" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Payment will be sent to the connected POS terminal." FontSize="13" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,12"/>
                    <Border Background="{StaticResource BrushBackground}" CornerRadius="8" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Status:" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding DeviceStatusText}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- UPI Panel -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.Upi}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="UPI Payment (Razorpay)" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Payment will be processed via Razorpay UPI integration." FontSize="13" Foreground="{StaticResource BrushTextMuted}" Margin="0,0,0,12"/>
                    <Border Background="{StaticResource BrushBackground}" CornerRadius="8" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Status:" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding DeviceStatusText}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Split Panel -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static vm:PaymentMode.Split}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Remaining:" FontSize="13" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding SplitRemainingFormatted}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource BrushNegative}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSplitBalanced}" Value="True">
                                                <Setter Property="Foreground" Value="#FF2E7D32"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource OutlineButton}" Content="+ Add Leg" Padding="10,6"
                                Command="{Binding AddSplitLegCommand}"
                                IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding SplitLegs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BrushSurface}" BorderBrush="{StaticResource BrushBorder}" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" MinWidth="120"
                                                  SelectedItem="{Binding Method}">
                                            <pay:PaymentProviderKind>Cash</pay:PaymentProviderKind>
                                            <pay:PaymentProviderKind>PineLabs</pay:PaymentProviderKind>
                                            <pay:PaymentProviderKind>Razorpay</pay:PaymentProviderKind>
                                        </ComboBox>

                                        <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" Margin="0,0,8,0" FontWeight="SemiBold"
                                                 Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"/>

                                        <Button Grid.Column="2" Content="✕" Width="28" Height="28" FontSize="12" Cursor="Hand"
                                                Background="Transparent" BorderThickness="0" Foreground="{StaticResource BrushNegative}"
                                                Command="{Binding DataContext.RemoveSplitLegCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Error message -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}" FontSize="13" Foreground="{StaticResource BrushNegative}" TextWrapping="Wrap" Margin="0,0,0,12">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="{x:Static vm:PaymentStatus.Failed}">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Action buttons -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Processing indicator -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Processing payment..." FontSize="13" Foreground="{StaticResource BrushTextMuted}" FontStyle="Italic"/>
            </StackPanel>

            <Button Grid.Column="1" Style="{StaticResource OutlineButton}" Content="Cancel" Margin="0,0,10,0" MinWidth="90"
                    Command="{Binding CancelCommand}"
                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>

            <Button Grid.Column="2" Style="{StaticResource PrimaryButton}" Content="Confirm Payment" MinWidth="140"
                    Command="{Binding ConfirmPaymentCommand}"
                    IsEnabled="{Binding IsProcessing, Converter={StaticResource InvertBool}}"/>
        </Grid>
    </Grid>
</Window>
