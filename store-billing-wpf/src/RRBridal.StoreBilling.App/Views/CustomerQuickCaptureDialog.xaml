<Window x:Class="RRBridal.StoreBilling.App.Views.CustomerQuickCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Customer"
        Width="440"
        SizeToContent="Height"
        MinWidth="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrushBackground}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Customer details" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource BrushText}"/>

        <TextBlock Grid.Row="1" Text="{Binding StatusText}" Foreground="{StaticResource BrushTextMuted}"
                   TextWrapping="Wrap" Margin="0,8,0,12"/>

        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Mobile no" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <TextBox x:Name="MobileBox" Grid.Column="1" Style="{StaticResource RoundedTextBox}"
                     Text="{Binding MobileNo, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,8"/>

            <TextBlock Grid.Row="1" Text="Customer name" VerticalAlignment="Center"/>
            <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Style="{StaticResource RoundedTextBox}"
                     Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <TextBlock x:Name="ValidationBlock" Grid.Row="3" Foreground="{StaticResource BrushNegative}"
                   TextWrapping="Wrap" Margin="0,0,0,8" Visibility="Collapsed"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Advanced search" Style="{StaticResource OutlineButton}" Margin="0,0,8,0"
                    Click="AdvancedSearch_OnClick" Visibility="{Binding ShowAdvancedSearch}"/>
            <Button Content="Cancel" Style="{StaticResource OutlineButton}" Margin="0,0,8,0" Width="80"
                    IsCancel="True" Click="Cancel_OnClick"/>
            <Button Content="Save" Style="{StaticResource PrimaryButton}" Width="90" IsDefault="True"
                    Click="Save_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
