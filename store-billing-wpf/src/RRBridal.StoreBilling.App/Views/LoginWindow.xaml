<Window x:Class="RRBridal.StoreBilling.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:RRBridal.StoreBilling.App.Views.Controls"
        Title="{Binding WindowTitleText}"
        Icon="pack://application:,,,/Resources/Assets/TruBill.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        MinWidth="440" MinHeight="500"
        Width="760" Height="540"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushAccent}"
        SizeChanged="LoginWindow_OnSizeChanged">
    <Grid x:Name="RootLayout">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="BrandColumn" Width="*" MinWidth="0"/>
            <ColumnDefinition Width="1.2*" MinWidth="280"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="BrandPanel" Grid.Column="0" Background="{StaticResource BrushAccent}" ClipToBounds="True">
            <Grid>
                <Ellipse Width="280" Height="280" Fill="White" Opacity="0.08"
                         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,-100,0,0"/>
                <Ellipse Width="200" Height="200" Fill="White" Opacity="0.06"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-60,-40"/>
                <StackPanel VerticalAlignment="Center" Margin="40,32">
                    <TextBlock Text="{Binding CompanyTitle}"
                               FontSize="28" FontWeight="Bold" Foreground="White"
                               Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <TextBlock Text="Sign in to continue billing at this counter."
                               FontSize="13.5" Foreground="#CCFFFFFF" TextWrapping="Wrap" LineHeight="20"/>
                    <Border Background="#22FFFFFF" CornerRadius="10" Padding="12,10" Margin="0,28,0,0"
                            HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="{Binding StoreDisplayName}" FontWeight="SemiBold" Foreground="White" FontSize="13"/>
                            <TextBlock Text="{Binding TillDisplayLine}" Foreground="#CCFFFFFF" FontSize="11.5" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource BrushSurface}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <StackPanel MaxWidth="400" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="40,48">
                    <controls:AppLogoMark LogoHeight="40" LogoMaxWidth="200" ShowTruPrefix="False"
                                          HorizontalAlignment="Left" Margin="0,0,0,20"/>
                    <TextBlock Text="Welcome back" FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource BrushText}" Margin="0,0,0,4"/>
                    <TextBlock Text="Use your email and password to open this till."
                               Style="{StaticResource PageSubtitle}" Margin="0,0,0,28"/>

                    <Border Margin="0,0,0,16">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource AlertBannerWarning}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SyncWarning}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SyncWarning}"
                                   Style="{StaticResource AlertTextWarning}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Email with inline placeholder -->
                    <Grid Margin="0,0,0,14" MinHeight="48">
                        <TextBox x:Name="EmailBox"
                                 Style="{StaticResource RoundedTextBox}"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" MinHeight="48" Padding="14,12"
                                 VerticalContentAlignment="Center"
                                 GotFocus="EmailBox_OnGotFocus"
                                 LostFocus="EmailBox_OnLostFocus"
                                 TextChanged="EmailBox_OnTextChanged"/>
                        <TextBlock x:Name="EmailPlaceholder"
                                   Text="Email address"
                                   IsHitTestVisible="False"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="14"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Grid MinHeight="48">
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource RoundedPasswordBox}"
                                     FontSize="14" MinHeight="48" Padding="14,12"
                                     VerticalContentAlignment="Center"
                                     GotFocus="PasswordBox_OnGotFocus"
                                     LostFocus="PasswordBox_OnLostFocus"
                                     PasswordChanged="PasswordBox_OnPasswordChanged"/>
                        <TextBlock x:Name="PasswordPlaceholder"
                                   Text="Password"
                                   IsHitTestVisible="False"
                                   Foreground="{StaticResource BrushTextMuted}"
                                   FontSize="14"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Margin="0,14,0,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource AlertBannerError}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Style="{StaticResource AlertTextError}"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Button Content="Sign in"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginCommand}"
                            HorizontalAlignment="Stretch"
                            MinHeight="48" FontSize="15" FontWeight="SemiBold"
                            Margin="0,22,0,0"
                            IsDefault="True"
                            IsEnabled="{Binding IsLoggingIn, Converter={StaticResource InvertBool}}"/>

                    <TextBlock Text="Signing in…"
                               HorizontalAlignment="Center" Margin="0,14,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
