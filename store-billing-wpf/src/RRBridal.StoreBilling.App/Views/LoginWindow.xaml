<Window x:Class="RRBridal.StoreBilling.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:RRBridal.StoreBilling.App.Views.Controls"
        Title="{Binding WindowTitleText}"
        Icon="pack://application:,,,/Resources/Assets/TruBill.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="440" Height="520"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">
    <Grid>
        <Border Style="{StaticResource CardBorder}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="380"
                Padding="32,28"
                Margin="0">
            <StackPanel>
                <controls:AppLogoMark LogoHeight="52" LogoMaxWidth="300" ShowTruPrefix="False" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="{Binding CompanyTitle}"
                           Style="{StaticResource TextPageTitle}"
                           Foreground="{StaticResource BrushAccent}"
                           FontWeight="Bold"
                           FontSize="26"
                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding StoreDisplayName}"
                           Style="{StaticResource TextBody}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,0,0,2"/>
                <TextBlock Text="{Binding TillDisplayLine}"
                           Style="{StaticResource TextCaption}"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <Border Margin="0,0,0,16">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource AlertBannerWarning}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SyncWarning}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding SyncWarning}"
                               Style="{StaticResource AlertTextWarning}"
                               TextWrapping="Wrap"/>
                </Border>

                <TextBlock Text="Email" Style="{StaticResource TextLabel}" Margin="0,0,0,6"/>
                <TextBox Style="{StaticResource RoundedTextBox}"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14"/>

                <TextBlock Text="Password" Style="{StaticResource TextLabel}" Margin="0,16,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource RoundedPasswordBox}"
                             FontSize="14"/>

                <Border Margin="0,12,0,0">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource AlertBannerError}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource AlertTextError}"
                               TextWrapping="Wrap"/>
                </Border>

                <Button Content="Login"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoginCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="0,12" FontSize="15"
                        Margin="0,24,0,0"
                        IsEnabled="{Binding IsLoggingIn, Converter={StaticResource InvertBool}}"/>

                <TextBlock Text="Logging in..."
                           HorizontalAlignment="Center" Margin="0,10,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
