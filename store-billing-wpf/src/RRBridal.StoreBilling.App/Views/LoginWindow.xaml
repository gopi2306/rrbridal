<Window x:Class="RRBridal.StoreBilling.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RR Bridal - Login"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Width="420" Height="480"
        Background="{StaticResource BrushBackground}">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">
        <StackPanel>
            <TextBlock Text="RR Bridal" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource BrushAccent}"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Store Billing" FontSize="16" FontWeight="Light"
                       Foreground="{StaticResource BrushText}"
                       HorizontalAlignment="Center" Margin="0,0,0,32"/>

            <Border Margin="0,0,0,16" Padding="10,8" CornerRadius="4"
                    Background="#FFF3CD" BorderBrush="#FFECB5" BorderThickness="1">
                <TextBlock Text="{Binding SyncWarning}"
                           Foreground="#664D03" FontSize="12"
                           TextWrapping="Wrap"/>
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SyncWarning}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <TextBlock Text="Email" Margin="0,0,0,6" Foreground="{StaticResource BrushText}"/>
            <TextBox Style="{StaticResource RoundedTextBox}"
                     Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                     Padding="10,8" FontSize="14"/>

            <TextBlock Text="Password" Margin="0,16,0,6" Foreground="{StaticResource BrushText}"/>
            <PasswordBox x:Name="PasswordBox"
                         Padding="10,8" FontSize="14"
                         BorderBrush="{StaticResource BrushBorder}"
                         BorderThickness="1"/>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red" FontSize="13"
                       Margin="0,12,0,0"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Button Content="Login"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding LoginCommand}"
                    HorizontalAlignment="Stretch"
                    Padding="0,12" FontSize="15"
                    Margin="0,24,0,0"
                    IsEnabled="{Binding IsLoggingIn, Converter={StaticResource InvertBool}}"/>

            <TextBlock Text="Logging in..."
                       FontSize="12" Foreground="{StaticResource BrushText}"
                       HorizontalAlignment="Center" Margin="0,8,0,0"
                       Opacity="0.6">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
