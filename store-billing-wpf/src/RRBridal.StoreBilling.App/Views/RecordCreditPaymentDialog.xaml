<Window x:Class="RRBridal.StoreBilling.App.Views.RecordCreditPaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt" SizeToContent="Height" Width="520" MinWidth="460"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">
    <Border Style="{StaticResource CardBorder}" Margin="16" Padding="24,20">
        <StackPanel>
            <TextBlock Text="Receipt" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}"/>
            <TextBlock x:Name="BalanceHintText" Foreground="{StaticResource BrushTextMuted}" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>

            <Border Background="{StaticResource BrushSidebarTint}" CornerRadius="8" Padding="14" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Text="Amount to collect (₹)" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,6"/>
                    <TextBox x:Name="AmountBox" Style="{StaticResource RoundedTextBox}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="RemainingPreviewText" Foreground="{StaticResource BrushAccent}" FontSize="12" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Payment mode" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,16,0,8"/>
            <WrapPanel Margin="0,0,0,4">
                <RadioButton x:Name="CashRadio" Content="Cash" IsChecked="True" Margin="0,0,12,8"/>
                <RadioButton x:Name="UpiRadio" Content="UPI" Margin="0,0,12,8"/>
                <RadioButton x:Name="CardRadio" Content="Card" Margin="0,0,12,8"/>
                <RadioButton x:Name="CreditNoteRadio" Content="Credit Note" Margin="0,0,12,8"/>
                <RadioButton x:Name="SplitRadio" Content="Split Payment" Margin="0,0,0,8"/>
            </WrapPanel>

            <!-- Single-mode reference -->
            <StackPanel x:Name="ReferencePanel" Margin="0,8,0,0">
                <TextBlock x:Name="ReferenceLabelText" Text="Transaction / reference no" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,6"/>
                <TextBox x:Name="TransactionNoBox" Style="{StaticResource RoundedTextBox}"/>
            </StackPanel>

            <!-- Credit note panel -->
            <StackPanel x:Name="CreditNotePanel" Margin="0,8,0,0" Visibility="Collapsed">
                <TextBlock Text="Customer credit note" Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,6"/>
                <ComboBox x:Name="CreditNoteCombo" MinHeight="36" Margin="0,0,0,8"
                          DisplayMemberPath="CreditNoteNo" SelectedValuePath="CreditNoteNo"/>
                <TextBlock Text="Or enter credit note no." Foreground="{StaticResource BrushTextMuted}" FontSize="11" Margin="0,0,0,6"/>
                <TextBox x:Name="CreditNoteRefBox" Style="{StaticResource RoundedTextBox}"/>
            </StackPanel>

            <!-- Split panel -->
            <StackPanel x:Name="SplitPanel" Margin="0,8,0,0" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Remaining:" FontSize="12" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock x:Name="SplitRemainingText" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="{StaticResource BrushNegative}"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Cash" FontSize="12" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="SplitCashBox" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Card" FontSize="12" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" x:Name="SplitCardBox" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="UPI" FontSize="12" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="SplitUpiBox" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Credit Note" FontSize="12" Foreground="{StaticResource BrushTextMuted}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="SplitCreditNoteAmountBox" Style="{StaticResource RoundedTextBox}" Margin="0,0,8,8"/>
                    <TextBox Grid.Row="3" Grid.Column="2" x:Name="SplitCreditNoteRefBox" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,8"
                             ToolTip="Credit note reference"/>
                </Grid>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancel" Style="{StaticResource OutlineButton}" MinWidth="96" Height="36" Margin="0,0,8,0" Click="Cancel_Click"/>
                <Button Content="Confirm" Style="{StaticResource PrimaryButton}" MinWidth="110" Height="36" Click="Confirm_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
