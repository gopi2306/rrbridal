<Window x:Class="RRBridal.StoreBilling.App.Views.CashHandOverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cash Hand Over"
        Width="520" Height="640"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource FontFamilyPrimary}"
        Background="{StaticResource BrushBackground}">
    <Window.InputBindings>
        <KeyBinding Key="F3" Command="{Binding PrintCommand}"/>
        <KeyBinding Key="F12" Command="{Binding ExitCommand}"/>
    </Window.InputBindings>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Cash Hand Over" Style="{StaticResource TextPageTitle}"
                   Foreground="{StaticResource BrushAccent}" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{Binding DateDisplay, StringFormat=Date: {0}}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding CounterDisplay, StringFormat=Counter: {0}}" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding UserDisplay, StringFormat=User: {0}}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
                <TextBlock Text="Cash taken" Foreground="{StaticResource BrushTextMuted}"/>
                <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding CashTaken, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding IsReadOnly}" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <DataGrid ItemsSource="{Binding Denominations}"
                      Style="{StaticResource ThemedDataGrid}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      IsReadOnly="{Binding IsReadOnly}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Rs." Binding="{Binding Denomination}" Width="70" IsReadOnly="True"/>
                    <DataGridTextColumn Header="No of Unit" Binding="{Binding UnitCountText, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding AmountDisplay}" Width="110" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Margin="0,12,0,0" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding CashInHandSummary, StringFormat=Cash In Hand: {0}}" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding MorningCashSummary, StringFormat=Morning Cash: {0}}" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding ExpectedCashSummary, StringFormat=Expected Cash: {0}}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding DifferenceSummary, StringFormat=Difference: {0}}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusLabel, StringFormat=Status: {0}}" Margin="0,6,0,0" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" MaxWidth="200"/>
            <Button Content="F3 Print" Style="{StaticResource OutlineButton}" Width="90" Margin="0,0,8,0"
                    Command="{Binding PrintCommand}"/>
                    <Button Content="Close day" Style="{StaticResource PrimaryButton}" Width="100" Margin="0,0,8,0"
                            Command="{Binding CloseDayCommand}"
                            Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
            <Button Content="F12 Exit" Style="{StaticResource OutlineButton}" Width="90"
                    Command="{Binding ExitCommand}"/>
        </StackPanel>
    </Grid>
</Window>
