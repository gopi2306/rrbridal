<UserControl x:Class="RRBridal.StoreBilling.App.Views.OnlineSalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Background="{StaticResource BrushBackground}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="0,0,0,8">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="200"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Online sales" Style="{StaticResource TextPageTitle}" Foreground="{StaticResource BrushAccent}"/>
            <TextBlock Text="Online COD orders — balance till until payment is recorded with transaction number."
                       Foreground="{StaticResource BrushTextMuted}" TextWrapping="Wrap" Margin="0,4,0,0"/>
        </StackPanel>

        <UniformGrid Grid.Row="1" Margin="0,0,0,12"
                     ui:UniformGridColumnsBehavior.IsEnabled="True"
                     ui:UniformGridColumnsBehavior.CompactColumns="1"
                     ui:UniformGridColumnsBehavior.MediumColumns="2"
                     ui:UniformGridColumnsBehavior.WideColumns="3">
            <Border Style="{StaticResource MetricCard}" Margin="0,0,8,0" BorderBrush="{StaticResource BrushAccent}">
                <StackPanel>
                    <TextBlock Text="Balance till" Style="{StaticResource TextCaption}"/>
                    <TextBlock Text="{Binding BalanceTillSummary}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="Pending orders" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                    <TextBlock Text="{Binding PendingCountSummary}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Received today" Foreground="{StaticResource BrushTextMuted}" FontSize="12"/>
                    <TextBlock Text="{Binding ReceivedTodaySummary}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="Bill no" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SearchBillNo, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,8">
                    <TextBlock Text="Customer name" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SearchCustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,8">
                    <TextBlock Text="Status" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <ComboBox Style="{StaticResource RoundedComboBox}" ItemsSource="{Binding StatusFilterOptions}"
                              SelectedItem="{Binding SelectedStatusFilter}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Date from" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding SearchDateFrom}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,0">
                    <TextBlock Text="Date to" Foreground="{StaticResource BrushTextMuted}" FontSize="11"/>
                    <DatePicker Style="{StaticResource RoundedDatePicker}" SelectedDate="{Binding SearchDateTo}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Search" Style="{StaticResource PrimaryButton}" Width="90" Margin="0,0,8,0" Command="{Binding SearchCommand}"/>
                    <Button Content="Refresh" Style="{StaticResource OutlineButton}" Width="90" Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="8">
            <DataGrid x:Name="ResultsGrid"
                      ItemsSource="{Binding Results}"
                      SelectedItem="{Binding SelectedOrder}"
                      Style="{StaticResource ThemedDataGrid}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      SelectionChanged="ResultsGrid_OnSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Bill no" Binding="{Binding BillNo}" Width="130"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding CreatedAtDisplay}" Width="100"/>
                    <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding CustomerPhone}" Width="110"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat=₹ {0:N2}}" Width="100"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="Txn no" Binding="{Binding TransactionNo}" Width="120"/>
                    <DataGridTextColumn Header="Pay mode" Binding="{Binding ReceivedPaymentMode}" Width="80"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource BrushTextMuted}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"
                       IsHitTestVisible="False"/>
            <Button Content="Record payment"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="160"
                    Padding="20,10"
                    HorizontalAlignment="Center"
                    Command="{Binding RecordPaymentCommand}"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</UserControl>
