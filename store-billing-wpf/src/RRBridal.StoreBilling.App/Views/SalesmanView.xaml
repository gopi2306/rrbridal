<UserControl x:Class="RRBridal.StoreBilling.App.Views.SalesmanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="clr-namespace:RRBridal.StoreBilling.App.Services.Ui"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1000"
             Background="{StaticResource BrushBackground}">
    <Grid Margin="0,0,0,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Salesman" Style="{StaticResource TextPageTitle}" Foreground="{StaticResource BrushAccent}"/>
                <TextBlock Text="Add floor sales staff and view salesman records for billing and reports."
                           Style="{StaticResource TextCaption}" TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>
            <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Content="Refresh" Style="{StaticResource OutlineButton}" MinWidth="100" Margin="0,0,8,4"
                        Command="{Binding RefreshCommand}"/>
                <Button Content="New salesman" Style="{StaticResource PrimaryButton}" MinWidth="130" Margin="0,0,0,4"
                        Command="{Binding NewSalesmanCommand}"/>
            </WrapPanel>
        </Grid>

        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="{StaticResource BrushTextMuted}"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>

        <Grid Grid.Row="2"
              ui:MasterDetailLayoutBehavior.IsEnabled="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="280"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="SEARCH" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8"/>
                        <Button Content="Search" Style="{StaticResource OutlineButton}" HorizontalAlignment="Left"
                                Command="{Binding RefreshCommand}" MinWidth="90"/>
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Salesmen}"
                              SelectedItem="{Binding SelectedSalesman}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              Style="{StaticResource ThemedDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding SalesmanCode}" Width="80"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="110"/>
                            <DataGridTextColumn Header="Active" Binding="{Binding IsActive}" Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="16"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Top">
                    <TextBlock Text="{Binding EditPanelTitle}"
                               FontWeight="SemiBold" Foreground="{StaticResource BrushAccent}" Margin="0,0,0,12"/>

                    <TextBlock Text="SALESMAN CODE" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding EditCode}" IsReadOnly="True"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="NAME *" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <TextBlock Text="PHONE" Style="{StaticResource TextLabel}" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource RoundedTextBox}" Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"/>

                    <CheckBox Content="Active" IsChecked="{Binding EditIsActive}" Margin="0,0,0,16"
                              Visibility="{Binding ShowEditIsActive, Converter={StaticResource BoolToVis}}"/>

                    <WrapPanel>
                        <Button Content="Save" Style="{StaticResource PrimaryButton}" MinWidth="100" Margin="0,0,8,4"
                                Command="{Binding SaveCommand}"/>
                        <Button Content="Cancel" Style="{StaticResource OutlineButton}" MinWidth="100" Margin="0,0,0,4"
                                Command="{Binding CancelEditCommand}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
