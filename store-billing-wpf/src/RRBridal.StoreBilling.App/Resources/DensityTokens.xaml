    <sys:Double x:Key="DensityInputMinHeight">30</sys:Double>
    <Thickness x:Key="DensityInputPadding">10,4</Thickness>
    <sys:Double x:Key="DensityInputFontSize">12.5</sys:Double>
    <sys:Double x:Key="DensityCompactInputMinHeight">26</sys:Double>
    <Thickness x:Key="DensityCompactInputPadding">6,2</Thickness>
    <sys:Double x:Key="DensityComboMinHeight">30</sys:Double>
    <Thickness x:Key="DensityButtonPadding">12,5</Thickness>
    <sys:Double x:Key="DensityButtonMinHeight">30</sys:Double>
    <Thickness x:Key="DensityCardPadding">14,12</Thickness>
    <Thickness x:Key="DensityFilterBarPadding">12,10</Thickness>
    <sys:Double x:Key="DensityPageTitleFontSize">22</sys:Double>
    <sys:Double x:Key="DensitySectionTitleFontSize">14.5</sys:Double>
    <sys:Double x:Key="DensityMetricValueFontSize">18</sys:Double>
    <Thickness x:Key="DensityContentMargin">12,8</Thickness>
    <sys:Double x:Key="DensityFormLabelMinWidth">110</sys:Double>
    <sys:Double x:Key="DensityDataGridRowHeight">28</sys:Double>
</ResourceDictionary>
