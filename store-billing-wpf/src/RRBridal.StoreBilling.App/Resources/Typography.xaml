<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="FontFamilyPrimary">Segoe UI Variable, Segoe UI</FontFamily>

    <Style x:Key="TextPageTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}"/>
        <Setter Property="FontSize" Value="{DynamicResource DensityPageTitleFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
    </Style>

    <Style x:Key="TextPageTitleAccent" TargetType="TextBlock" BasedOn="{StaticResource TextPageTitle}">
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="TextSectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}"/>
        <Setter Property="FontSize" Value="{DynamicResource DensitySectionTitleFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
    </Style>

    <Style x:Key="TextBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
    </Style>

    <Style x:Key="TextCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}"/>
        <Setter Property="FontSize" Value="11.5"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
    </Style>

    <Style x:Key="TextLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
    </Style>

    <Style x:Key="FilterFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
        <Setter Property="Margin" Value="0,0,0,5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="MetricValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyPrimary}"/>
        <Setter Property="FontSize" Value="{DynamicResource DensityMetricValueFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource BrushText}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="MetricValueAccent" TargetType="TextBlock" BasedOn="{StaticResource MetricValue}">
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
    </Style>

    <Style x:Key="FormFieldLabel" TargetType="TextBlock" BasedOn="{StaticResource TextLabel}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="TextMuted" TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
        <Setter Property="Foreground" Value="{StaticResource BrushTextMuted}"/>
    </Style>

    <Style x:Key="TextAccent" TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="PageSubtitle" TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
</ResourceDictionary>
