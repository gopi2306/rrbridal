# Must match central store `code` and stock transfer `toStoreId` exactly, or sync pull will not return transfers for this till.
# Multi-counter / ZeroTier parent-Mongo: same STORE_ID + STORE_MONGO_URI (parent ZeroTier IP); unique DEVICE_ID and POS_COUNTER per till.
# See deploy/env.counter-*.example and deploy/ZEROTIER_PARENT_MONGO.md.
STORE_ID=store-001
DEVICE_ID=counter-01
POS_COUNTER=1
STORE_MONGO_URI=mongodb://localhost:27017/rr_bridal_store
CENTRAL_API_BASE=http://localhost:3000
# Auto central sync interval (minutes). Counter 1 (POS_COUNTER=1) only. 0 = off. Default 5.
SYNC_INTERVAL_MINUTES=5
# Optional ZeroTier-friendly Mongo timeouts (defaults: 20 / 20 / 45).
# STORE_MONGO_CONNECT_TIMEOUT_SECONDS=20
# STORE_MONGO_SERVER_SELECTION_TIMEOUT_SECONDS=20
# STORE_MONGO_HEALTH_INTERVAL_SECONDS=45
# Block app start until Mongo is reachable (default true). Set false for local without gate.
# STORE_MONGO_REQUIRE_READY=true
