# Counter 1 — copy to .env beside RRBridal.StoreBilling.App.exe
#
# Parent-Mongo / ZeroTier mode (Option B):
# - All counters share the SAME STORE_MONGO_URI pointing at the parent ZeroTier IP.
# - Unique DEVICE_ID + POS_COUNTER per till.
# - Auto-sync (products/transfers/outbox) runs on counter 1 only.
#
# Ops checklist:
# 1) Parent Mongo binds 0.0.0.0 (not only localhost)
# 2) Firewall allows TCP 27017 on the ZeroTier interface
# 3) Both counters can ping the parent ZeroTier IP
# 4) Prefer a Stable ZeroTier IP; update every counter .env if it changes
# 5) Keep POS1 online for scheduled central sync

STORE_ID=store-001
DEVICE_ID=counter-01
POS_COUNTER=1
STORE_MONGO_URI=mongodb://10.147.20.1:27017/rr_bridal_store01
CENTRAL_API_BASE=http://bridaldev.rrbazaar.in
# Manager till: auto sync products/transfers to shared store Mongo (minutes). 0 = off.
SYNC_INTERVAL_MINUTES=5
# Longer timeouts help flaky ZeroTier links (defaults: 20 / 20 / 45).
STORE_MONGO_CONNECT_TIMEOUT_SECONDS=20
STORE_MONGO_SERVER_SELECTION_TIMEOUT_SECONDS=20
# Optional: STORE_MONGO_SOCKET_TIMEOUT_SECONDS=60
STORE_MONGO_HEALTH_INTERVAL_SECONDS=45
# true = block app start until parent Mongo is reachable (ZeroTier mode).
# false = allow start even if Mongo is down (local / no ZeroTier gate).
STORE_MONGO_REQUIRE_READY=true
