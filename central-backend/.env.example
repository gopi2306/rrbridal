PORT=3000
MONGO_URI=mongodb://localhost:27017/rr_bridal_central
JWT_SECRET=replace_me
JWT_ISSUER=rr-bridal
JWT_AUDIENCE=rr-bridal-clients
RAZORPAY_KEY_ID=replace_me
RAZORPAY_KEY_SECRET=replace_me
# Flow-wise demo data (SKU-001…005, PO-1001, promos). Clear with: npm run seed:clear-test-data
SEED_TEST_DATA=false

# Production: only super_admin role + admin@gmail.com on startup (no demo stores/users)
SEED_PRODUCTION=true
# Clear demo users/roles once: npm run seed:clear-users-roles

# --- MongoDB daily backup (scripts/mongo-backup/) ---
# Master switch: true = run mongodump on schedule; false = skip (exit cleanly)
BACKUP_ENABLED=false
# linux | windows — must match the script you schedule (backup-mongo.sh or backup-mongo.ps1)
BACKUP_PLATFORM=linux
# Dated dump folders root. Defaults if empty: /var/backups/rr-bridal/mongo (linux) or C:\data\rr-bridal\mongo-backups (windows)
BACKUP_PATH=/var/backups/rr-bridal/mongo
# Delete dated folders older than this many days
BACKUP_RETENTION_DAYS=10
# true = copy this .env into each day's folder as env.backup
BACKUP_INCLUDE_ENV=false
